#!/bin/sh /etc/rc.common

START=90
STOP=10
USE_PROCD=1

NAME=vipin-vpn
PROG=/usr/bin/easytier

get_config() {
    config_load vipin
    config_get_bool enabled vpn enabled 0
    config_get_bool split_tunnel vpn split_tunnel 0
    config_get server vpn server ""
    config_get port vpn port 3000
    config_get auth_token vpn auth_token ""
    config_get country vpn country "cn"
}

start_service() {
    get_config
    
    [ "$enabled" = "0" ] && return 1
    
    mkdir -p /var/log
    mkdir -p /etc/vipin
    
    if [ -z "$server" ] || [ -z "$auth_token" ]; then
        logger -t $NAME "VPN not configured, skipping start"
        return 1
    fi
    
    /usr/sbin/vipin-country-ips update "$country" 2>/dev/null
    
    procd_open_instance
    procd_set_param command $PROG
    procd_append_param command -i easytier
    procd_append_param command -c /etc/easytier
    procd_append_param command -n "$server"
    procd_append_param command -p "$port"
    procd_append_param command -t "password=$auth_token"
    procd_append_param command -l /var/log/easytier.log
    procd_append_param command -d
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
    
    sleep 2
    
    if [ "$split_tunnel" = "1" ]; then
        /usr/sbin/vipin-vpn-routing enable "$country"
    fi
    
    logger -t $NAME "VPN started (server: $server:$port)"
}

stop_service() {
    get_config
    
    /usr/sbin/vipin-vpn-routing disable 2>/dev/null
    
    killall easytier 2>/dev/null
    
    logger -t $NAME "VPN stopped"
}

reload_service() {
    stop_service
    sleep 1
    start_service
}

restart() {
    stop_service
    sleep 1
    start_service
}

status() {
    if pgrep -x easytier >/dev/null; then
        echo "VPN is running"
        return 0
    else
        echo "VPN is not running"
        return 1
    fi
}

boot() {
    get_config
    
    [ "$enabled" = "1" ] && {
        sleep 30
        start_service
    }
}
