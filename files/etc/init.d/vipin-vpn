#!/bin/sh /etc/rc.common

START=90
STOP=10
USE_PROCD=1

NAME=vipin-vpn

# MOCK mode: functions can be sourced for tests without side effects.
VIPIN_VPN_MOCK="${VIPIN_VPN_MOCK:-0}"

resolve_connect_server() {
    # Returns the hostname stunnel should actually connect to.
    # UCI-selected server is what the user picked (and what we display);
    # if they picked cn.fanq.in but the router is outside CN, we connect
    # to un.fanq.in — an overseas frontend that forwards CN traffic to cn2.
    # Treats un as a cn alias so the rest of the codebase doesn't care.
    local router_country uci_server base_domain
    if [ "$VIPIN_VPN_MOCK" = "1" ]; then
        router_country="$VIPIN_VPN_ROUTER_COUNTRY"
        uci_server="$VIPIN_VPN_UCI_SERVER"
        base_domain="$VIPIN_VPN_BASE_DOMAIN"
    else
        # Use vipin-country-ips get-country to match the detection used in
        # start_service. vipin-detect with no subcommand prints usage, not JSON;
        # get-country returns just the 2-letter code (empty if not yet detected).
        router_country=$(/usr/sbin/vipin-country-ips get-country 2>/dev/null)
        [ -z "$router_country" ] && router_country="$(uci -q get vipin.vpn.country || echo cn)"
        uci_server=$(uci -q get vipin.vpn.server)
        base_domain=$(uci -q get vipin.vpn.base_domain || echo fanq.in)
    fi
    if [ "$router_country" != "cn" ] && \
       echo "$uci_server" | grep -q "^cn\.${base_domain}$"; then
        echo "un.${base_domain}"
    else
        echo "$uci_server"
    fi
}

fetch_auth_params() {
    # POST /api/v1/router-auth source=stunnel with creds, write response to
    # $VIPIN_CONFIG_DIR/auth-params.json.
    # Exit codes: 0=ok, 1=expired/invalid, 2=network error.
    local username="$1" password="$2" mac="$3"
    local cfgdir="${VIPIN_CONFIG_DIR:-/etc/vipin}"
    local api_base response status
    mkdir -p "$cfgdir"

    if [ "$VIPIN_VPN_MOCK" = "1" ]; then
        response="$VIPIN_VPN_API_RESPONSE"
    else
        api_base=$(uci -q get vipin.vpn.site_url || echo "https://www.anyfq.com")
        response=$(wget -q -O- --timeout=10 \
            "${api_base}/api/v1/router-auth" \
            --post-data="username=${username}&credentials=${password}&mac=${mac}&source=stunnel" \
            2>/dev/null)
    fi

    if [ -z "$response" ]; then
        return 2
    fi

    echo "$response" > "$cfgdir/auth-params.json"
    status=$(echo "$response" | grep -o '"status":"[^"]*"' | cut -d'"' -f4)
    case "$status" in
        ok) return 0 ;;
        expired|invalid|not_vip) return 1 ;;
        *) return 2 ;;
    esac
}

extract_ca_cert() {
    # Pull ca_cert field out of auth-params.json into a PEM file.
    local cfgdir="${VIPIN_CONFIG_DIR:-/etc/vipin}"
    local params="$cfgdir/auth-params.json"
    [ -f "$params" ] || return 1
    # The ca_cert value is JSON-string with \n escapes — unescape to real newlines.
    awk 'match($0, /"ca_cert":"[^"]*"/) {
        s = substr($0, RSTART+11, RLENGTH-12)
        gsub(/\\n/, "\n", s)
        print s
    }' "$params" > "$cfgdir/stunnel-ca.pem"
    [ -s "$cfgdir/stunnel-ca.pem" ]
}

render_stunnel_conf() {
    # Build the stunnel client config from auth-params.json + resolved server.
    local cfgdir="${VIPIN_CONFIG_DIR:-/etc/vipin}"
    local params="$cfgdir/auth-params.json"
    [ -f "$params" ] || return 1

    local port connect_host
    port=$(grep -o '"port":[0-9]*' "$params" | head -1 | cut -d: -f2)
    connect_host=$(resolve_connect_server)
    [ -z "$port" ] || [ -z "$connect_host" ] && return 1

    # Anti-fingerprint: for JP servers, server-side DNATs ports
    # 45000-49999 → 22, so we can pick a random high port per connect
    # line. GFW can still SNI-match the TLS ClientHello, but fixed
    # :22-on-every-reconnect is a stronger signal than randomized high
    # ports. Gated behind vipin.vpn.port_randomize (default 0) — the
    # server-side DNAT setup is an ops step that may lag the router
    # firmware rollout, and with randomize=1 but no DNAT every connect
    # RSTs (Connection refused on 45000-49999). Default-off ensures a
    # safe baseline; flip to 1 via UCI once the port bank is live.
    local server_country_prefix port_randomize
    server_country_prefix=$(echo "$connect_host" | cut -d. -f1)
    port_randomize=$(uci -q get vipin.vpn.port_randomize || echo 0)
    local randomize_port=0
    if [ "$port_randomize" = "1" ]; then
        case "$server_country_prefix" in
            jp|jp[0-9]*) randomize_port=1 ;;
        esac
    fi

    # Pull optional DNS sidecar endpoint from the server response. Used when
    # overseas-router + CN-server — see configure_dns decision matrix.
    local dns_host dns_port
    dns_host=$(grep -o '"stunnel_host":"[^"]*"' "$params" | cut -d'"' -f4)
    dns_port=$(grep -o '"stunnel_port":[0-9]*' "$params" | head -1 | cut -d: -f2)

    # Resolve connect_host to every A record and emit one `connect = IP:port`
    # per record. stunnel's `failover = rr` only rotates across multiple
    # connect lines — given a single hostname connect it caches the first
    # resolved IP and sticks there forever, even across restarts (verified
    # live: 6 tunnels all hit 47.242.64.28 despite 3 A records). DNS is
    # already ready by the time we get here since fetch_auth_params just
    # completed a successful API round-trip.
    local ips
    ips=$(nslookup "$connect_host" 2>/dev/null | awk '/^Address.*:/ && $NF ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$/ { print $NF }')
    [ -z "$ips" ] && ips="$connect_host"

    cat > "$cfgdir/stunnel-client.conf" <<EOF
; Generated by vipin-vpn start_service — do not edit by hand.
pid = /var/run/vipin-stunnel.pid
foreground = yes
; Aggressive memory discipline for 128 MB routers. Without these, stunnel
; grows past 30 MB RSS under LAN traffic and gets OOM-killed repeatedly.
debug = 2
output = /dev/null
; Per-thread stack 64 KB (default 2 MB) — biggest single saving.
stack = 65536
; Limit entropy collection to what OpenSSL actually needs.
RNDbytes = 256
socket = l:TCP_NODELAY=1
socket = r:TCP_NODELAY=1
socket = l:SO_KEEPALIVE=1
socket = r:SO_KEEPALIVE=1

[vipn]
client = yes
accept = 127.0.0.1:1080
EOF
    for ip in $ips; do
        local real_port="$port"
        if [ "$randomize_port" = "1" ]; then
            # Random in [45000, 49999]. busybox ash supports $RANDOM
            # (0-32767 from /dev/urandom-ish source), good enough for
            # per-connect port dispersion. Server-side DNAT folds the
            # whole range to :22.
            real_port=$(( 45000 + RANDOM % 5000 ))
        fi
        echo "connect = ${ip}:${real_port}" >> "$cfgdir/stunnel-client.conf"
    done
    cat >> "$cfgdir/stunnel-client.conf" <<EOF
failover = rr
CAfile = ${cfgdir}/stunnel-ca.pem
verifyChain = yes
; checkHost stays the hostname — cert CN is un.fanq.in regardless of which
; backend IP stunnel picks, so hostname validation still passes.
checkHost = ${connect_host}
; Close initiator-side immediately (default is 60s lingering half-close).
; Leaves TIMEOUTidle at stunnel's upstream default (43200s = 12h) — earlier
; override at 60s was killing long-lived SSH / WebSocket / video-keepalive
; flows every minute of quiet for a memory saving that doesn't materially
; help on a residential-traffic router.
TIMEOUTclose = 0
EOF

}

configure_dns() {
    # Decide which dnsmasq upstream(s) to use and (in non-MOCK mode) write
    # the config. Prints a summary string to stdout either way.
    #
    # 3-way decision matrix (VPN is assumed UP when this is called):
    #   router in CN                              → un.fanq.in:3333  (TCP+UDP socat
    #                                                → un local dnsmasq, in-tunnel)
    #   router overseas + CN srv + dns.txt ready  → delegate to vipin-dns-refresh
    #                                                (multi CN upstream + all-servers
    #                                                 + /32 WAN routes)
    #   everything else                           → WAN DNS          (ISP-assigned)
    #
    # When VPN is down, teardown_dns() runs and also picks WAN DNS.
    local router_country uci_server base_domain server_country upstream wan_dns
    if [ "$VIPIN_VPN_MOCK" = "1" ]; then
        router_country="$VIPIN_VPN_ROUTER_COUNTRY"
        uci_server="$VIPIN_VPN_UCI_SERVER"
        base_domain="$VIPIN_VPN_BASE_DOMAIN"
        wan_dns="${VIPIN_VPN_WAN_DNS:-1.1.1.1}"
    else
        router_country=$(/usr/sbin/vipin-country-ips get-country 2>/dev/null)
        [ -z "$router_country" ] && router_country="$(uci -q get vipin.vpn.country || echo cn)"
        uci_server=$(uci -q get vipin.vpn.server)
        base_domain=$(uci -q get vipin.vpn.base_domain || echo fanq.in)
        wan_dns=$(/usr/sbin/vipin-wan-dns-ip 2>/dev/null | head -1)
        [ -z "$wan_dns" ] && wan_dns="1.1.1.1"
    fi

    # un is a cn alias for split-tunnel and DNS purposes.
    server_country=$(echo "$uci_server" | cut -d. -f1)
    [ "$server_country" = "un" ] && server_country="cn"

    # Probe un.fanq.in:3333 reachability before pointing dnsmasq at it.
    # If the tunnel hasn't punched through yet (or un is down), using
    # 47.242.64.28#3333 as upstream = instant DNS death. Fall back to
    # WAN DNS; watchdog reload_dns hook flips back when 3333 recovers.
    local un_dns_ok=0
    if [ "$VIPIN_VPN_MOCK" = "1" ]; then
        [ "$VIPIN_VPN_UN_DNS_OK" = "1" ] && un_dns_ok=1
    else
        nslookup -timeout=3 -port=3333 www.anyfq.com 47.242.64.28 \
            >/dev/null 2>&1 && un_dns_ok=1
    fi

    if [ "$router_country" = "cn" ] && [ "$un_dns_ok" = "1" ]; then
        upstream="47.242.64.28#3333"
    elif [ "$router_country" = "cn" ]; then
        upstream="$wan_dns"
        [ "$VIPIN_VPN_MOCK" != "1" ] && logger -t "$NAME" \
            "configure_dns: un.fanq.in:3333 not responding — WAN DNS fallback; watchdog will re-sync"
    elif [ "$server_country" = "cn" ] && [ -s /etc/vipin/dns.txt ]; then
        # vipin-dns-refresh owns the UCI server list + all-servers flag +
        # /32 WAN routes. Sentinel path — skip the single-upstream UCI write
        # below so we don't clobber the multi-server config.
        if [ "$VIPIN_VPN_MOCK" != "1" ]; then
            /usr/sbin/vipin-dns-refresh 2>/dev/null || \
                logger -t "$NAME" "vipin-dns-refresh failed — dnsmasq config unchanged"
        fi
        echo "dns.txt (multi CN, all-servers)"
        return 0
    else
        upstream="$wan_dns"
    fi

    if [ "$VIPIN_VPN_MOCK" != "1" ]; then
        uci -q delete dhcp.@dnsmasq[0].server
        uci -q delete dhcp.@dnsmasq[0].allservers
        uci add_list dhcp.@dnsmasq[0].server="$upstream"
        uci set dhcp.@dnsmasq[0].noresolv='1'
        uci commit dhcp
        /etc/init.d/dnsmasq restart >/dev/null 2>&1
    fi
    echo "$upstream"
}

teardown_dns() {
    # VPN stopped: fall back to WAN DNS (ISP DHCP-assigned). un.fanq.in:3333
    # is unreachable without the tunnel, so we MUST have an out-of-tunnel
    # fallback or the router goes DNS-dark.
    local wan_dns
    if [ "$VIPIN_VPN_MOCK" != "1" ]; then
        wan_dns=$(/usr/sbin/vipin-wan-dns-ip 2>/dev/null | head -1)
        [ -z "$wan_dns" ] && wan_dns="1.1.1.1"
        uci -q delete dhcp.@dnsmasq[0].server
        uci add_list dhcp.@dnsmasq[0].server="$wan_dns"
        uci set dhcp.@dnsmasq[0].noresolv='1'
        uci commit dhcp
        /etc/init.d/dnsmasq restart >/dev/null 2>&1
    fi
}

get_config() {
    config_load vipin
    config_get_bool split_tunnel vpn split_tunnel 1
    config_get server vpn server ""
    config_get username vpn username ""
    config_get country vpn country "cn"
    config_get base_domain vpn base_domain "fanq.in"
    config_get site_url vpn site_url "https://www.anyfq.com"
}

check_auth() {
    local status
    status=$(/usr/sbin/vipin-auth status 2>/dev/null)
    echo "$status" | grep -q '"logged_in": *true'
}

start_service() {
    # Single-instance lock. Without this, watchdog's 30s tick +
    # hotplug's WAN-ifup fire can run two `start` in parallel: first
    # instance spawns stunnel/hev, second sees "stack already up" in
    # the idempotent check below and exits — BUT if the second races
    # in while the first hasn't yet spawned hev, both go into
    # render-config + spawn path and fight over /etc/vipin/stunnel-
    # client.conf, /etc/vipin/hev-tun.yaml, tun0 device, and the
    # procd_open_instance registration. Witnessed 2026-04-24 on a
    # live router with two stuck `vipin-vpn start` processes and
    # stunnel never reaching ESTAB. Non-blocking flock: late arrivals
    # skip quietly instead of queueing.
    exec 7>/var/lock/vipin-start.lock
    if ! flock -n 7; then
        logger -t "$NAME" "start_service: another start in progress, skipping"
        return 0
    fi

    # Idempotent front-door. Any caller (procd, hotplug, LuCI API,
    # watchdog) may invoke start — if the stack is healthy we no-op
    # immediately instead of re-rendering config and respawning
    # stunnel/hev (which was the root cause of the 2026-04-21 tun0
    # timeout race on 192.168.2.110).
    if pgrep stunnel >/dev/null 2>&1 && \
       pgrep hev-socks5-tunnel >/dev/null 2>&1 && \
       ip link show tun0 >/dev/null 2>&1; then
        logger -t "$NAME" "start_service: stack already up, no-op"
        return 0
    fi

    get_config

    check_auth || return 1

    mkdir -p /var/log /etc/vipin /tmp/vipin

    local auth_info username pass_file
    auth_info=$(/usr/sbin/vipin-auth status 2>/dev/null)
    username=$(echo "$auth_info" | grep -o '"username": *"[^"]*"' | cut -d'"' -f4)
    pass_file="/etc/vipin/.vpn_pass"

    if [ -z "$username" ] || [ ! -f "$pass_file" ]; then
        logger -t "$NAME" "VPN not configured, skipping start"
        return 1
    fi

    local password mac
    password=$(cat "$pass_file")
    mac=$(/usr/sbin/vipin-auth mac 2>/dev/null | \
          grep -o '"mac": *"[^"]*"' | cut -d'"' -f4)

    # Only revert to WAN DNS if the current dnsmasq can't resolve the auth
    # domain — e.g. upgrade from an older build that left 127.0.0.1#5356
    # (retired stubby bridge) as the upstream. The new three-CN-DNS stack
    # is independent of the VPN tunnel (/32 WAN routes), so in the common
    # restart case we keep the working config to preserve dnsmasq cache.
    if ! nslookup -timeout=3 www.anyfq.com 127.0.0.1 >/dev/null 2>&1; then
        logger -t "$NAME" "Local DNS unreachable pre-auth, reverting to WAN DNS"
        teardown_dns
    fi

    # Wait up to 60s for the auth API to be resolvable. On cold boot
    # netifd may fire ifup on wan before DHCP-learned DNS is in
    # resolv.conf.auto; vipin-vpn is START=90 and can race ahead of
    # that. Without this wait, fetch_auth_params's wget returns empty
    # and start_service exits — watchdog eventually retries 45s later,
    # but the user sees "VPN down" for 1-2 min post-boot. Polling until
    # DNS works shortens that to whatever DHCP takes (typically <10s).
    local api_host
    api_host=$(uci -q get vipin.vpn.site_url | sed 's|https\?://||;s|/.*||')
    [ -z "$api_host" ] && api_host="www.anyfq.com"
    local i=0
    while [ "$i" -lt 20 ]; do
        nslookup -timeout=3 "$api_host" >/dev/null 2>&1 && break
        sleep 3
        i=$((i + 1))
    done
    if [ "$i" -ge 20 ]; then
        logger -t "$NAME" "DNS not ready for $api_host after 60s — letting watchdog retry"
        return 1
    fi

    fetch_auth_params "$username" "$password" "$mac"
    case $? in
        0) ;;  # ok — proceed
        1) logger -t "$NAME" "Auth expired/invalid, not starting VPN"
           uci set vipin.vpn.auth_status="$(grep -o '"status":"[^"]*"' /etc/vipin/auth-params.json | cut -d'"' -f4)"
           uci commit vipin
           return 1 ;;
        2) logger -t "$NAME" "Auth API unreachable on start, deferring"
           return 1 ;;
    esac

    uci set vipin.vpn.auth_status='ok'
    uci commit vipin

    extract_ca_cert || {
        logger -t "$NAME" "Failed to extract CA cert"
        return 1
    }
    render_stunnel_conf || {
        logger -t "$NAME" "Failed to render stunnel config"
        return 1
    }

    ip link delete tun0 2>/dev/null

    local connect_host
    connect_host=$(resolve_connect_server)
    logger -t "$NAME" "Starting stunnel client → ${connect_host}:$(grep -o '"port":[0-9]*' /etc/vipin/auth-params.json | head -1 | cut -d: -f2)"

    # Bypass routes for stunnel's upstream IPs — must ALWAYS go direct via
    # WAN, never via tun0. Without these, `0.0.0.0/1 dev tun0` (installed
    # below once tun0 is up) swallows stunnel's own SYNs to its upstream,
    # and when tun0 goes zombie (hev waiting for handshake that never
    # completes) stunnel can never reconnect — textbook chicken-and-egg.
    # replace (not add) so reboot/restart re-applies cleanly.
    local wan_gw wan_dev
    wan_gw=$(ip route show default 2>/dev/null | awk '/default/ {print $3; exit}')
    wan_dev=$(ip route show default 2>/dev/null | awk '/default/ {print $5; exit}')
    if [ -n "$wan_gw" ] && [ -n "$wan_dev" ]; then
        grep -oE 'connect = [0-9.]+:[0-9]+' /etc/vipin/stunnel-client.conf 2>/dev/null | \
            awk '{split($3,a,":"); print a[1]}' | sort -u | while read ip; do
                ip route replace "$ip/32" via "$wan_gw" dev "$wan_dev" 2>/dev/null
            done
        logger -t "$NAME" "stunnel upstream bypass routes installed via $wan_gw dev $wan_dev"
    fi

    # No procd respawn on stunnel/hev sub-processes: vipin-auth-check
    # owns stack health (is_stack_running + DNS canary, 30s loop with 45s
    # min-interval + flock). Letting procd also respawn creates double-restart
    # churn where procd bounces one process while watchdog is bouncing the
    # whole stack. Crash recovery still happens — just single-sourced.
    procd_open_instance stunnel
    procd_set_param command /usr/bin/stunnel /etc/vipin/stunnel-client.conf
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    cat > /etc/vipin/hev-tun.yaml << 'YAML'
tunnel:
  name: tun0
  mtu: 8500
  multi-queue: true
  ipv4: 192.168.200.1/24
socks5:
  address: 127.0.0.1
  port: 1080
  udp: 'tcp'
misc:
  task-stack-size: 20480
  log-file: stderr
  log-level: warn
YAML

    procd_open_instance tun2socks
    procd_set_param command /usr/bin/hev-socks5-tunnel /etc/vipin/hev-tun.yaml
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    # Poll for tun0 — hev-socks5-tunnel brings the device up only after
    # stunnel has handshaken, which on MT7628-class boxes can take 20s+
    # under WAN latency. If the poll expires before tun0 shows up,
    # vipin-auth-check's 30s watchdog reinstates the default routes
    # as soon as the device appears.
    ( i=0
      while [ "$i" -lt 30 ]; do
          ip link show tun0 >/dev/null 2>&1 && break
          sleep 1
          i=$((i + 1))
      done
      if ip link show tun0 >/dev/null 2>&1; then
          ip link set tun0 up 2>/dev/null
          ip route add 0.0.0.0/1 dev tun0 2>/dev/null
          ip route add 128.0.0.0/1 dev tun0 2>/dev/null
          local split_mode country dns_upstream
          split_mode=$(uci -q get vipin.vpn.split_mode || echo forward)
          if [ "$split_mode" = "reverse" ]; then
              # reverse: server-country IPs go through VPN (so user picks up
              # that country's egress). un is a cn alias.
              country=$(echo "$(uci -q get vipin.vpn.server)" | cut -d. -f1)
              [ "$country" = "un" ] && country="cn"
              /usr/sbin/vipin-vpn-routing enable "$country" reverse
          elif [ "$split_mode" = "forward" ]; then
              # forward: router-location IPs stay on direct WAN, the rest
              # goes through VPN. Use the auto-detected router country, not
              # the static uci vpn.country (which is a server-side hint).
              country=$(/usr/sbin/vipin-country-ips get-country 2>/dev/null)
              [ -z "$country" ] && country="$(uci -q get vipin.vpn.country || echo cn)"
              /usr/sbin/vipin-vpn-routing enable "$country" forward
          fi
          # Split-tunnel policy is loaded. Probe un.fanq.in:3333 reachability
          # over the tunnel before flipping dnsmasq upstream — if 3333 isn't
          # answering yet (tunnel still establishing), pointing dnsmasq at it
          # would DNS-dark the router. Tick every second up to 30s.
          local dns_wait=0
          while [ "$dns_wait" -lt 30 ]; do
              nslookup -timeout=2 -port=3333 www.anyfq.com 47.242.64.28 \
                  >/dev/null 2>&1 && break
              sleep 1
              dns_wait=$((dns_wait + 1))
          done
          if [ "$dns_wait" -ge 30 ]; then
              logger -t "$NAME" "un.fanq.in:3333 not responding after 30s — DNS stays on WAN; will retry on next watchdog tick"
          else
              logger -t "$NAME" "un.fanq.in:3333 ready in ${dns_wait}s"
              dns_upstream=$(configure_dns)
              logger -t "$NAME" "DNS upstream set to $dns_upstream"
          fi
          logger -t "$NAME" "VPN started"
      else
          logger -t "$NAME" "tun0 did not come up in 30s"
      fi
    ) &
}

stop_service() {
    get_config

    /usr/sbin/vipin-vpn-routing disable 2>/dev/null

    killall stunnel 2>/dev/null
    killall hev-socks5-tunnel 2>/dev/null
    sleep 1

    ip route del 0.0.0.0/1 dev tun0 2>/dev/null
    ip route del 128.0.0.0/1 dev tun0 2>/dev/null
    ip link delete tun0 2>/dev/null

    # Skip the DNS teardown during restart — start_service will re-apply the
    # correct CN-DNS config via vipin-dns-refresh. Avoiding this intermediate
    # dnsmasq restart preserves the 10k-entry cache across the restart window
    # and prevents LAN clients from seeing a "DNS down" blip.
    [ "$VIPIN_VPN_SKIP_TEARDOWN" = "1" ] || teardown_dns

    rm -f /var/run/vipin-stunnel.pid

    logger -t "$NAME" "VPN stopped"
}

_restart_locked() {
    VIPIN_VPN_SKIP_TEARDOWN=1
    stop_service
    VIPIN_VPN_SKIP_TEARDOWN=0
    sleep 1
    start_service
}

reload_service() {
    # Non-blocking lock: if another restart is already in progress, drop this
    # one instead of queueing. Concurrent restart storms (LuCI + watchdog +
    # user) would otherwise pile up on procd_lock for minutes.
    ( flock -n 8 || { logger -t "$NAME" "restart already in progress, skipping"; exit 0; }
      _restart_locked
    ) 8>/var/lock/vipin-restart.lock
}

restart() {
    ( flock -n 8 || { logger -t "$NAME" "restart already in progress, skipping"; exit 0; }
      _restart_locked
    ) 8>/var/lock/vipin-restart.lock
}

status() {
    # With USE_PROCD=1, rc.common overrides this function with procd's own
    # wrapper (which prints just "running"). Keep this for the direct-invoke
    # case and for shells without procd — it's never the LuCI code path.
    if pgrep stunnel >/dev/null && pgrep hev-socks5-tunnel >/dev/null && \
       ip link show tun0 >/dev/null 2>&1; then
        echo "VPN is running"
        local auth_info username
        auth_info=$(/usr/sbin/vipin-auth status 2>/dev/null)
        username=$(echo "$auth_info" | grep -o '"username": *"[^"]*"' | cut -d'"' -f4)
        [ -n "$username" ] && echo "User: $username"
        return 0
    fi
    echo "VPN is not running"
    return 1
}

boot() {
    # Deterministic first-boot ordering — no race with hotplug auto-login.
    #
    # If baked credentials are waiting in /etc/vipin/auto-login, the
    # hotplug handler /etc/hotplug.d/iface/90-vipin-auto-login is the
    # SOLE authority on first WAN ifup: it does vipin-auth login, writes
    # UCI (server + split_mode), then calls /etc/init.d/vipin-vpn start.
    # boot() must NOT run in that window or it races with hotplug.
    #
    # Reboot path (no auto-login file, auth.conf + .vpn_pass already
    # present from a previous login): boot() owns the bringup, with a
    # 10 s grace for the network to settle.
    [ -f /etc/vipin/auto-login ] && {
        logger -t "$NAME" "boot(): deferring to hotplug auto-login (baked creds pending)"
        return 0
    }
    ( sleep 10
      [ -f /etc/vipin/auth.conf ] && [ -f /etc/vipin/.vpn_pass ] || exit 0
      /etc/init.d/vipin-auth start 2>/dev/null
      start_service
    ) &
}
