#!/bin/sh /etc/rc.common

START=90
STOP=10
USE_PROCD=1

NAME=vipin-vpn
PROG=/usr/sbin/openconnect

SERVERS_API="https://www.anyfq.com/api/v1/servers"

get_config() {
    config_load vipin
    config_get_bool enabled vpn enabled 0
    config_get_bool split_tunnel vpn split_tunnel 1
    config_get server vpn server ""
    config_get username vpn username ""
    config_get country vpn country "cn"
}

check_auth() {
    local status=$(/usr/sbin/vipin-auth status 2>/dev/null)
    
    if echo "$status" | grep -q '"logged_in": *true'; then
        return 0
    fi
    
    logger -t $NAME "Authentication required, cannot start VPN"
    return 1
}

fetch_cert_pin() {
    local srv="$1"
    local pin_file="/etc/vipin/cert_pin"

    # Try to get cert pin from server API
    local response=$(wget -q -O- --timeout=10 \
        "https://www.anyfq.com/api/v1/servers" 2>/dev/null)

    if [ -n "$response" ]; then
        # Extract cert_pin for this server
        local pin=$(echo "$response" | grep -o "\"${srv}\"[^}]*\"cert_pin\":\"[^\"]*\"" | grep -o '"cert_pin":"[^"]*"' | cut -d'"' -f4)
        if [ -n "$pin" ]; then
            echo "$pin" > "$pin_file"
            return 0
        fi
    fi

    # Fallback: use a dummy pin to get the real one from openconnect error
    if [ ! -f "$pin_file" ]; then
        local err=$(echo "" | openconnect --protocol=anyconnect --server "$srv:443" \
            --servercert pin-sha256:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA= \
            --passwd-on-stdin 2>&1 | grep "pin-sha256:")
        local real_pin=$(echo "$err" | grep -o 'pin-sha256:[A-Za-z0-9+/=]*')
        if [ -n "$real_pin" ]; then
            echo "$real_pin" > "$pin_file"
            return 0
        fi
    fi

    return 1
}

get_cert_pin() {
    local pin_file="/etc/vipin/cert_pin"
    if [ -f "$pin_file" ]; then
        cat "$pin_file"
    else
        echo ""
    fi
}

start_service() {
    get_config
    
    [ "$enabled" = "0" ] && return 1
    
    if ! check_auth; then
        return 1
    fi
    
    mkdir -p /var/log
    mkdir -p /etc/vipin
    mkdir -p /tmp/vipin
    
    local auth_info=$(/usr/sbin/vipin-auth status 2>/dev/null)
    local username=$(echo "$auth_info" | grep -o '"username": *"[^"]*"' | cut -d'"' -f4)
    local pass_file="/etc/vipin/.vpn_pass"

    if [ -z "$server" ] || [ -z "$username" ]; then
        logger -t $NAME "VPN not configured, skipping start"
        return 1
    fi

    if [ ! -f "$pass_file" ]; then
        logger -t $NAME "VPN password file not found, re-login required"
        return 1
    fi

    logger -t $NAME "Starting VPN for user: $username"
    
    local current_country=$(/usr/sbin/vipin-country-ips get-country 2>/dev/null)
    [ -n "$current_country" ] && country="$current_country"
    
    /usr/sbin/vipin-country-ips update "$country" 2>/dev/null
    
    if pgrep -x openconnect >/dev/null; then
        logger -t $NAME "VPN already running"
        return 0
    fi
    
    local vpn_port=$((50000 + RANDOM % 10000))

    fetch_cert_pin "$server"
    local cert_pin=$(get_cert_pin)
    local cert_opt=""
    if [ -n "$cert_pin" ]; then
        cert_opt="--servercert $cert_pin"
    fi

    logger -t $NAME "Connecting to $server:$vpn_port"

    # Create wrapper script to pipe password to openconnect via stdin
    cat > /tmp/vipin/vpn_start.sh << SCRIPT
#!/bin/sh
cat "$pass_file" | $PROG \
    --protocol=anyconnect \
    --server "$server:$vpn_port" \
    --useragent "OpenConnect VPN Agent" \
    --authgroup "" \
    --user "$username" \
    --passwd-on-stdin \
    $cert_opt \
    --interface vpn_vipin \
    --pid-file /var/run/vipin-vpn.pid \
    2>/var/log/openconnect.log
SCRIPT
    chmod +x /tmp/vipin/vpn_start.sh

    procd_open_instance
    procd_set_param command /bin/sh /tmp/vipin/vpn_start.sh
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
    
    sleep 3
    
    if pgrep -x openconnect >/dev/null; then
        logger -t $NAME "VPN started (server: $server)"
        
        if [ "$split_tunnel" = "1" ]; then
            /usr/sbin/vipin-vpn-routing enable "$country"
        fi
    else
        logger -t $NAME "Failed to start VPN"
        cat /var/log/openconnect.log 2>/dev/null | tail -5 | logger -t $NAME
        return 1
    fi
}

stop_service() {
    get_config
    
    /usr/sbin/vipin-vpn-routing disable 2>/dev/null
    
    if pgrep -x openconnect >/dev/null; then
        killall openconnect 2>/dev/null
        sleep 2
    fi
    
    rm -f /var/run/vipin-vpn.pid
    
    logger -t $NAME "VPN stopped"
}

reload_service() {
    stop_service
    sleep 1
    start_service
}

restart() {
    stop_service
    sleep 1
    start_service
}

status() {
    if pgrep -x openconnect >/dev/null; then
        echo "VPN is running"
        local auth_info=$(/usr/sbin/vipin-auth status 2>/dev/null)
        local username=$(echo "$auth_info" | grep -o '"username": *"[^"]*"' | cut -d'"' -f4)
        if [ -n "$username" ]; then
            echo "User: $username"
        fi
        return 0
    else
        echo "VPN is not running"
        return 1
    fi
}

boot() {
    get_config

    [ "$enabled" = "1" ] && {
        # Wait for network to be ready
        sleep 30
        # Start auth monitor (handles reconnection)
        /etc/init.d/vipin-auth start 2>/dev/null
        # Start VPN
        start_service
    }
}
