#!/bin/sh
# Configure dnsmasq to use dnscrypt-proxy as upstream DNS

dnsmasq_cfg="/etc/config/dhcp"

# Wait for base system to initialize
sleep 2

# Ensure dnsmasq config exists
[ ! -f "$dnsmasq_cfg" ] && {
    cat > "$dnsmasq_cfg" << 'EOF'
config dnsmasq
	option domainneeded '1'
	option localise_queries '1'
	option rebind_protection '1'
	option rebind_localhost '1'
	option local '/lan/'
	option domain 'lan'
	option expandhosts '1'
	option authoritative '1'
	option readethers '1'
	option leasefile '/tmp/dhcp.leases'
	option resolvfile '/tmp/resolv.conf.d/resolv.conf.auto'
	option localservice '1'

config dhcp 'lan'
	option interface 'lan'
	option start '100'
	option limit '150'
	option leasetime '12h'

config dhcp 'wan'
	option interface 'wan'
	option ignore '1'
EOF
}

# Configure dnsmasq to use dnscrypt-proxy exclusively (ignore WAN DHCP DNS)
uci -q set dhcp.@dnsmasq[0].noresolv='1'
uci -q set dhcp.@dnsmasq[0].resolvfile=''
uci -q delete dhcp.@dnsmasq[0].server
uci -q add_list dhcp.@dnsmasq[0].server='127.0.0.1#5353'
uci -q commit dhcp

# Prevent WAN DHCP/DHCPv6 from injecting ISP DNS into the system resolver
for wan_if in wan wan6; do
    uci -q get network.${wan_if} >/dev/null 2>&1 || continue
    uci -q set network.${wan_if}.peerdns='0'
    uci -q delete network.${wan_if}.dns
done
uci -q commit network

/etc/init.d/dnsmasq restart 2>/dev/null
/etc/init.d/network reload 2>/dev/null

# Enable dnscrypt-proxy on boot
/etc/init.d/dnscrypt-proxy enable 2>/dev/null
/etc/init.d/dnscrypt-proxy start 2>/dev/null

rm -f /etc/uci-defaults/luci-dns-dnscrypt
exit 0
