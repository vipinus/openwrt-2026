#!/bin/sh

# Set hostname
uci set system.@system[0].hostname='202604'
uci commit system

# Set root password
echo -e 'www.anyfq.com\nwww.anyfq.com' | passwd root

# Set LAN IP
uci set network.lan.ipaddr='192.168.11.1'
uci set network.lan.netmask='255.255.255.0'
uci commit network

# Force generate wireless config if not exists
[ ! -f /etc/config/wireless ] && wifi detect > /etc/config/wireless

# Wait for wireless config to be generated
sleep 1

# Enable WiFi and set defaults
for radio in $(uci show wireless | grep "=wireless-device" | cut -d. -f2); do
    uci set wireless.$radio.disabled='0'
    
    # Find the first wifi-iface for this radio
    iface=$(uci show wireless | grep "device='$radio'" | cut -d. -f2 | head -1)
    
    if [ -n "$iface" ]; then
        uci set wireless.$iface.ssid='www.anyfq.com'
        uci set wireless.$iface.encryption='psk2'
        uci set wireless.$iface.key='www.anyfq.com'
    fi
done

# Commit and bring up WiFi
uci commit wireless
wifi up

# Reload network
/etc/init.d/network reload

exit 0
