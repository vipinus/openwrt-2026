#!/bin/sh
# VIPIN Server List - Fetch and cache server list

SERVERS_API="https://www.anyfq.com/api/v1/servers"
CACHE_FILE="/tmp/vipin/servers.json"
CACHE_TTL=3600

mkdir -p /tmp/vipin

fetch_servers() {
    local tmp_file="/tmp/vipin/servers_new.json"
    
    wget -q -O "$tmp_file" "$SERVERS_API" 2>/dev/null || \
    curl -s -o "$tmp_file" "$SERVERS_API" 2>/dev/null
    
    if [ -s "$tmp_file" ]; then
        mv "$tmp_file" "$CACHE_FILE"
        return 0
    else
        rm -f "$tmp_file"
        return 1
    fi
}

get_servers() {
    if [ -f "$CACHE_FILE" ]; then
        local age=$(($(date +%s) - $(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0)))
        if [ "$age" -lt "$CACHE_TTL" ]; then
            cat "$CACHE_FILE"
            return 0
        fi
    fi
    
    fetch_servers && cat "$CACHE_FILE"
}

list_countries() {
    get_servers | grep -o '"name":"[^"]*"' | cut -d'"' -f4 | sort
}

get_server_by_country() {
    local country="$1"
    get_servers | grep -A1 "\"name\":\"$country\"" | grep "server" | cut -d'"' -f4
}

case "$1" in
    list)
        get_servers
        ;;
    countries)
        list_countries
        ;;
    server)
        get_server_by_country "$2"
        ;;
    update)
        fetch_servers
        ;;
    *)
        echo "Usage: $0 {list|countries|server <country>|update}"
        ;;
esac
