#!/bin/sh
# VIPIN Server List - Fetch and cache server list
# Robust JSON parsing using sed

SERVERS_API="https://www.anyfq.com/api/v1/servers"
CACHE_FILE="/tmp/vipin/servers.json"
BASE_DOMAIN=$(uci get vipin.vpn.base_domain 2>/dev/null || echo "fanq.in")
CACHE_TTL=3600

mkdir -p /tmp/vipin

fetch_servers() {
    local tmp_file="/tmp/vipin/servers_new.json"
    
    wget -q -O "$tmp_file" "$SERVERS_API" 2>/dev/null || \
    curl -s -o "$tmp_file" "$SERVERS_API" 2>/dev/null
    
    if [ -s "$tmp_file" ]; then
        mv "$tmp_file" "$CACHE_FILE"
        return 0
    else
        rm -f "$tmp_file"
        return 1
    fi
}

get_servers() {
    if [ -f "$CACHE_FILE" ]; then
        local age=$(($(date +%s) - $(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0)))
        if [ "$age" -lt "$CACHE_TTL" ]; then
            cat "$CACHE_FILE"
            return 0
        fi
    fi
    
    fetch_servers && cat "$CACHE_FILE"
}

list_countries() {
    local servers_json=$(get_servers)
    local domains=$(echo "$servers_json" | sed -n 's/.*"domain":"\([^"]*\)".*/\1/gp' | sort)
    if [ -z "$domains" ]; then
        domains=$(uci get vipin.vpn.server 2>/dev/null)
        [ -n "$domains" ] && echo "$domains"
    else
        echo "$domains"
    fi
}

get_server_by_country() {
    local country="$1"
    local servers_json=$(get_servers)
    local host=$(echo "$servers_json" | sed -n 's/.*"domain":"'"$country"'".*"host":"\([^"]*\)".*/\1/p' | head -1)
    if [ -z "$host" ]; then
        host="${country}.${BASE_DOMAIN}"
    fi
    echo "$host"
}

case "$1" in
    list)
        get_servers
        ;;
    countries)
        list_countries
        ;;
    server)
        get_server_by_country "$2"
        ;;
    update)
        fetch_servers
        ;;
    *)
        echo "Usage: $0 {list|countries|server <country>|update}"
        ;;
esac
