#!/bin/sh

LANG_FILE="/etc/vipin_lang"
DEFAULT_LANG="en"

get_language() {
    if [ -f "$LANG_FILE" ]; then
        cat "$LANG_FILE"
    else
        echo "$DEFAULT_LANG"
    fi
}

set_language() {
    local lang="$1"
    echo "$lang" > "$LANG_FILE"
}

get_translation() {
    local lang="${1:-en}"
    local key="$2"
    
    case "$lang" in
        zh|zh-CN|zh-TW)
            case "$key" in
                update_available) echo "发现新版本可用" ;;
                current_version) echo "当前版本" ;;
                latest_version) echo "最新版本" ;;
                up_to_date) echo "已是最新版本" ;;
                checking) echo "正在检查更新..." ;;
                check_failed) echo "检查更新失败" ;;
                download_now) echo "立即下载" ;;
                firmware_update) echo "固件更新" ;;
                new_version) echo "发现新版本" ;;
                *) echo "$key" ;;
            esac
            ;;
        ja)
            case "$key" in
                update_available) echo "新しいバージョンがあります" ;;
                current_version) echo "現在のバージョン" ;;
                latest_version) echo "最新バージョン" ;;
                up_to_date) echo "最新です" ;;
                checking) echo "更新を確認中..." ;;
                check_failed) echo "更新の確認に失敗しました" ;;
                download_now) echo "今すぐダウンロード" ;;
                firmware_update) echo "ファームウェア更新" ;;
                new_version) echo "新しいバージョンがあります" ;;
                *) echo "$key" ;;
            esac
            ;;
        ko)
            case "$key" in
                update_available) echo "새 버전을 사용할 수 있습니다" ;;
                current_version) echo "현재 버전" ;;
                latest_version) echo "최신 버전" ;;
                up_to_date) echo "최신 상태입니다" ;;
                checking) echo "업데이트 확인 중..." ;;
                check_failed) echo "업데이트 확인 실패" ;;
                download_now) echo "지금 다운로드" ;;
                firmware_update) echo "펌웨어 업데이트" ;;
                new_version) echo "새 버전 가능" ;;
                *) echo "$key" ;;
            esac
            ;;
        ru)
            case "$key" in
                update_available) echo "Доступна новая версия" ;;
                current_version) echo "Текущая версия" ;;
                latest_version) echo "Последняя версия" ;;
                up_to_date) echo "У вас последняя версия" ;;
                checking) echo "Проверка обновлений..." ;;
                check_failed) echo "Ошибка проверки обновлений" ;;
                download_now) echo "Скачать сейчас" ;;
                firmware_update) echo "Обновление прошивки" ;;
                new_version) echo "Доступна новая версия" ;;
                *) echo "$key" ;;
            esac
            ;;
        es)
            case "$key" in
                update_available) echo "Nueva versión disponible" ;;
                current_version) echo "Versión actual" ;;
                latest_version) echo "Última versión" ;;
                up_to_date) echo "Está actualizado" ;;
                checking) echo "Buscando actualizaciones..." ;;
                check_failed) echo "Error al buscar actualizaciones" ;;
                download_now) echo "Descargar ahora" ;;
                firmware_update) echo "Actualización de firmware" ;;
                new_version) echo "Nueva versión disponible" ;;
                *) echo "$key" ;;
            esac
            ;;
        de)
            case "$key" in
                update_available) echo "Neue Version verfügbar" ;;
                current_version) echo "Aktuelle Version" ;;
                latest_version) echo "Neueste Version" ;;
                up_to_date) echo "Sie sind auf dem neuesten Stand" ;;
                checking) echo "Suche nach Updates..." ;;
                check_failed) echo "Update-Prüfung fehlgeschlagen" ;;
                download_now) echo "Jetzt herunterladen" ;;
                firmware_update) echo "Firmware-Update" ;;
                new_version) echo "Neue Version verfügbar" ;;
                *) echo "$key" ;;
            esac
            ;;
        fr)
            case "$key" in
                update_available) echo "Nouvelle version disponible" ;;
                current_version) echo "Version actuelle" ;;
                latest_version) echo "Dernière version" ;;
                up_to_date) echo "Vous êtes à jour" ;;
                checking) echo "Recherche de mises à jour..." ;;
                check_failed) echo "Échec de la vérification des mises à jour" ;;
                download_now) echo "Télécharger maintenant" ;;
                firmware_update) echo "Mise à jour du firmware" ;;
                new_version) echo "Nouvelle version disponible" ;;
                *) echo "$key" ;;
            esac
            ;;
        pt)
            case "$key" in
                update_available) echo "Nova versão disponível" ;;
                current_version) echo "Versão atual" ;;
                latest_version) echo "Última versão" ;;
                up_to_date) echo "Você está atualizado" ;;
                checking) echo "Verificando atualizações..." ;;
                check_failed) echo "Falha ao verificar atualizações" ;;
                download_now) echo "Baixar agora" ;;
                firmware_update) echo "Atualização de firmware" ;;
                new_version) echo "Nova versão disponível" ;;
                *) echo "$key" ;;
            esac
            ;;
        vi)
            case "$key" in
                update_available) echo "Phiên bản mới có sẵn" ;;
                current_version) echo "Phiên bản hiện tại" ;;
                latest_version) echo "Phiên bản mới nhất" ;;
                up_to_date) echo "Bạn đã cập nhật" ;;
                checking) echo "Đang kiểm tra cập nhật..." ;;
                check_failed) echo "Kiểm tra cập nhật thất bại" ;;
                download_now) echo "Tải xuống ngay" ;;
                firmware_update) echo "Cập nhật firmware" ;;
                new_version) echo "Phiên bản mới có sẵn" ;;
                *) echo "$key" ;;
            esac
            ;;
        th)
            case "$key" in
                update_available) echo "มีเวอร์ชันใหม่" ;;
                current_version) echo "เวอร์ชันปัจจุบัน" ;;
                latest_version) echo "เวอร์ชันล่าสุด" ;;
                up_to_date) echo "คุณเป็นปัจจุบันแล้ว" ;;
                checking) echo "กำลังตรวจสอบการอัปเดต..." ;;
                check_failed) echo "การตรวจสอบการอัปเดตล้มเหลว" ;;
                download_now) echo "ดาวน์โหลดเลย" ;;
                firmware_update) echo "อัปเดตเฟิร์มแวร์" ;;
                new_version) echo "มีเวอร์ชันใหม่" ;;
                *) echo "$key" ;;
            esac
            ;;
        id)
            case "$key" in
                update_available) echo "Versi baru tersedia" ;;
                current_version) echo "Versi saat ini" ;;
                latest_version) echo "Versi terbaru" ;;
                up_to_date) echo "Anda sudah yang terbaru" ;;
                checking) echo "Memeriksa pembaruan..." ;;
                check_failed) echo "Gagal memeriksa pembaruan" ;;
                download_now) echo "Unduh sekarang" ;;
                firmware_update) echo "Pembaruan firmware" ;;
                new_version) echo "Versi baru tersedia" ;;
                *) echo "$key" ;;
            esac
            ;;
        ar)
            case "$key" in
                update_available) echo "الإصدار الجديد متاح" ;;
                current_version) echo "الإصدار الحالي" ;;
                latest_version) echo "أحدث إصدار" ;;
                up_to_date) echo "أنت على أحدث إصدار" ;;
                checking) echo "جارٍ البحث عن التحديثات..." ;;
                check_failed) echo "فشل التحقق من التحديثات" ;;
                download_now) echo "التحميل الآن" ;;
                firmware_update) echo "تحديث البرنامج الثابت" ;;
                new_version) echo "الإصدار الجديد متاح" ;;
                *) echo "$key" ;;
            esac
            ;;
        fa)
            case "$key" in
                update_available) echo "نسخه جدید موجود است" ;;
                current_version) echo "نسخه فعلی" ;;
                latest_version) echo "آخرین نسخه" ;;
                up_to_date) echo "شما به روز هستید" ;;
                checking) echo "در حال بررسی به‌روزرسانی..." ;;
                check_failed) echo "خطا در بررسی به‌روزرسانی" ;;
                download_now) echo "دانلود حالا" ;;
                firmware_update) echo "به‌روزرسانی فریمور" ;;
                new_version) echo "نسخه جدید موجود است" ;;
                *) echo "$key" ;;
            esac
            ;;
        hi)
            case "$key" in
                update_available) echo "नया संस्करण उपलब्ध" ;;
                current_version) echo "वर्तमान संस्करण" ;;
                latest_version) echo "नवीनतम संस्करण" ;;
                up_to_date) echo "आप अद्यतन हैं" ;;
                checking) echo "अपडेट की जांच हो रही है..." ;;
                check_failed) echo "अपडेट जांच विफल" ;;
                download_now) echo "अभी डाउनलोड करें" ;;
                firmware_update) echo "फर्मवेयर अपडेट" ;;
                new_version) echo "नया संस्करण उपलब्ध" ;;
                *) echo "$key" ;;
            esac
            ;;
        tr)
            case "$key" in
                update_available) echo "Yeni sürüm mevcut" ;;
                current_version) echo "Mevcut sürüm" ;;
                latest_version) echo "En son sürüm" ;;
                up_to_date) echo "Güncel durumdasınız" ;;
                checking) echo "Güncelleme kontrolü..." ;;
                check_failed) echo "Güncelleme kontrolü başarısız" ;;
                download_now) echo "Şimdi indir" ;;
                firmware_update) echo "Firmware güncellemesi" ;;
                new_version) echo "Yeni sürüm mevcut" ;;
                *) echo "$key" ;;
            esac
            ;;
        *)
            case "$key" in
                update_available) echo "New version available" ;;
                current_version) echo "Current version" ;;
                latest_version) echo "Latest version" ;;
                up_to_date) echo "You are up to date" ;;
                checking) echo "Checking for updates..." ;;
                check_failed) echo "Failed to check for updates" ;;
                download_now) echo "Download now" ;;
                firmware_update) echo "Firmware Update" ;;
                new_version) echo "New version available" ;;
                *) echo "$key" ;;
            esac
            ;;
    esac
}
