#!/bin/sh
# VIPIN User Authentication - Check user validity against RADIUS database
# Supports MAC address binding (one router per user)
# Encryption key fetched dynamically from server

CONF_DIR="/etc/vipin"
AUTH_FILE="$CONF_DIR/auth.conf"
LOG_FILE="/var/log/vipin-auth.log"
TOKEN_FILE="$CONF_DIR/renewal_token"
SITE_URL=$(uci get vipin.vpn.site_url 2>/dev/null || echo "https://www.anyfq.com")
RENEWAL_URL="${SITE_URL}/renew"
API_BASE="${SITE_URL}"
KEY_FILE="$CONF_DIR/.key"
DB_HOST="localhost"
DB_USER="root"
DB_PASS="e4b3k7y8"
DB_NAME="radius"
SECRET_KEY="vipin-router-2026-secret-key"
DEFAULT_MAC="00:00:00:00:00:00"
KEY_VERSION=1

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

mysql_query() {
    mysql -h "$DB_HOST" -u "$DB_USER" -p"$DB_PASS" -D "$DB_NAME" -s -N -e "$1" 2>/dev/null
}

fetch_encryption_key() {
    local router_mac=$(get_router_mac)
    local key_url="${API_BASE}/api/v1/router/key?v=${KEY_VERSION}&mac=${router_mac}"
    
    local response=$(wget -q -O- --timeout=10 "$key_url" 2>/dev/null)
    
    if [ -z "$response" ]; then
        log "Failed to fetch encryption key from server"
        return 1
    fi
    
    local key=$(echo "$response" | grep -o '"key":"[^"]*"' | cut -d'"' -f4)
    
    if [ -z "$key" ]; then
        log "Invalid key response: $response"
        return 1
    fi
    
    mkdir -p "$CONF_DIR"
    echo "$key" > "$KEY_FILE"
    chmod 600 "$KEY_FILE"
    
    log "Encryption key fetched and saved"
    return 0
}

load_encryption_key() {
    if [ -f "$KEY_FILE" ]; then
        cat "$KEY_FILE"
    else
        fetch_encryption_key
        cat "$KEY_FILE" 2>/dev/null
    fi
}

get_encryption_key() {
    local key=$(load_encryption_key)
    if [ -z "$key" ]; then
        key="0123456789abcdef0123456789abcdef"
    fi
    echo "$key"
}

get_router_mac() {
    local wan_if=$(uci get network.wan.device 2>/dev/null || echo "wan")
    local mac=""
    
    mac=$(ip link show "$wan_if" 2>/dev/null | grep ether | awk '{print $2}')
    
    if [ -z "$mac" ] || [ "$mac" = "" ]; then
        mac=$(cat /sys/class/net/eth0/address 2>/dev/null)
    fi
    
    if [ -z "$mac" ] || [ "$mac" = "" ]; then
        mac=$(ifconfig 2>/dev/null | grep -i 'ether' | awk '{print $2}' | head -1)
    fi
    
    echo "$mac"
}

parse_date() {
    local date_str="$1"
    date -d "$date_str" +%s 2>/dev/null || echo "0"
}

get_password() {
    local username="$1"
    mysql_query "SELECT value FROM radcheck WHERE username='$username' AND attribute='Cleartext-Password' LIMIT 1;"
}

get_expiration() {
    local username="$1"
    local exp=$(mysql_query "SELECT value FROM radcheck WHERE username='$username' AND attribute='Expiration' LIMIT 1;")
    [ -z "$exp" ] && exp=$(mysql_query "SELECT value FROM raduser WHERE username='$username' AND attribute='PayDate' LIMIT 1;")
    echo "$exp"
}

get_user_type() {
    local username="$1"
    mysql_query "SELECT value FROM raduser WHERE username='$username' AND attribute='Type' LIMIT 1;"
}

get_mac() {
    local username="$1"
    mysql_query "SELECT value FROM raduser WHERE username='$username' AND attribute='Mac' LIMIT 1;"
}

update_mac() {
    local username="$1"
    local mac="$2"
    mysql_query "UPDATE raduser SET value='$mac' WHERE username='$username' AND attribute='Mac' LIMIT 1;"
    log "MAC bound for $username: $mac"
}

check_password() {
    local username="$1"
    local password="$2"
    
    local stored_pass=$(get_password "$username")
    
    if [ -z "$stored_pass" ]; then
        return 1
    fi
    
    [ "$password" = "$stored_pass" ] && return 0 || return 1
}

is_vip() {
    local username="$1"
    local user_type=$(get_user_type "$username")
    
    [ -z "$user_type" ] && return 1
    [ "$user_type" = "normal" ] && return 1
    
    return 0
}

is_expired() {
    local username="$1"
    local expiration=$(get_expiration "$username")
    
    if [ -z "$expiration" ] || [ "$expiration" = "" ]; then
        return 1
    fi
    
    local exp_timestamp=$(parse_date "$expiration")
    local now=$(date +%s)
    
    [ "$exp_timestamp" -lt "$now" ] && return 0 || return 1
}

check_mac() {
    local username="$1"
    local router_mac="$2"
    
    if [ -z "$router_mac" ] || [ "$router_mac" = "" ]; then
        log "Cannot get router MAC address"
        return 1
    fi
    
    local db_mac=$(get_mac "$username")
    
    if [ "$db_mac" = "$DEFAULT_MAC" ] || [ -z "$db_mac" ]; then
        update_mac "$username" "$router_mac"
        return 0
    fi
    
    if [ "$db_mac" = "$router_mac" ]; then
        log "MAC verified for $username: $router_mac"
        return 0
    fi
    
    log "MAC mismatch for $username: DB=$db_mac Router=$router_mac"
    return 1
}

get_router_model() {
    local model=$(cat /etc/vipin_model 2>/dev/null)
    [ -z "$model" ] && model="Unknown"
    echo "$model"
}

urlencode() {
    echo -n "$1" | sed 's/%/%25/g;s/ /%20/g;s/!/%21/g;s/"/%22/g;s/#/%23/g;s/\$/%24/g;s/\&/%26/g;s/'\''/%27/g;s/(/%28/g;s/)/%29/g;s/\*/%2A/g;s/+/%2B/g;s/,/%2C/g;s/:/%3A/g;s/;/%3B/g;s/=/%3D/g;s/?/%3F/g;s/@/%40/g;s/\[/%5B/g;s/\]/%5D/g'
}

remote_auth() {
    local username="$1"
    local password="$2"
    local router_mac="$3"
    local router_model=$(get_router_model)

    local auth_url="${API_BASE}/api/v1/router-auth"

    local enc_username=$(urlencode "$username")
    local enc_password=$(urlencode "$password")
    local enc_mac=$(urlencode "$router_mac")
    local enc_model=$(urlencode "$router_model")

    # Retry up to 3 times: on first boot, dnscrypt-proxy takes ~60s to
    # bootstrap its resolver list. If user hits "Save Account" within that
    # window, wget returns empty (DNS unresolvable) and the caller would
    # treat the account as invalid. Worst case: 3 × (15+3) = 54s.
    local response attempt
    for attempt in 1 2 3; do
        response=$(wget -q -O- --timeout=15 \
            --post-data="username=$enc_username&password=$enc_password&mac=$enc_mac&source=router-plain&model=$enc_model" \
            "$auth_url" 2>/dev/null)
        [ -n "$response" ] && break
        [ "$attempt" -lt 3 ] && sleep 3
    done

    echo "$response"
}

authenticate() {
    local username="$1"
    local password="$2"
    local router_mac="$3"

    log "Authenticating user: $username (MAC: $router_mac)"

    local response=$(remote_auth "$username" "$password" "$router_mac")
    
    if [ -z "$response" ]; then
        log "Remote auth failed, falling back to local auth"
        local_auth "$username" "$password" "$router_mac"
        return $?
    fi
    
    local status=$(echo "$response" | grep -o '"status":"[^"]*"' | cut -d'"' -f4)
    
    case "$status" in
        valid)
            local user_type=$(echo "$response" | grep -o '"type":"[^"]*"' | cut -d'"' -f4)
            local expiration=$(echo "$response" | grep -o '"expiration":"[^"]*"' | cut -d'"' -f4)
            log "Remote auth success for $username ($user_type)"
            echo "{\"status\": \"valid\", \"message\": \"Authentication successful\", \"username\": \"$username\", \"type\": \"$user_type\", \"expiration\": \"$expiration\"}"
            return 0
            ;;
        expired)
            log "Account expired for: $username"
            echo "{\"status\": \"expired\", \"message\": \"Account has expired\"}"
            return 1
            ;;
        mac_mismatch)
            log "MAC mismatch for: $username"
            echo "{\"status\": \"mac_mismatch\", \"message\": \"Router MAC does not match registered device\"}"
            return 1
            ;;
        invalid)
            log "Invalid credentials for: $username"
            echo "{\"status\": \"invalid\", \"message\": \"Invalid username or password\"}"
            return 1
            ;;
        not_vip)
            log "User is not VIP: $username"
            echo "{\"status\": \"not_vip\", \"message\": \"Not a VIP user\"}"
            return 1
            ;;
        *)
            log "Unknown response: $response, falling back to local auth"
            local_auth "$username" "$password" "$router_mac"
            return $?
            ;;
    esac
}

local_auth() {
    local username="$1"
    local password="$2"
    local router_mac="$3"

    # Local database auth not available on router (no MySQL)
    # Only remote API auth is supported. Return a distinct status so the
    # UI can distinguish "DNS/network not ready yet" (typical on cold flash
    # first boot) from "credentials rejected" — showing the latter for what
    # is actually the former causes users to think their account is bad.
    log "Local auth not available, remote API required"
    echo "{\"status\": \"network_error\", \"message\": \"Network not ready, please retry in a moment\"}"
    return 1

    # Legacy local auth code below (requires MySQL, not available on router)
    if ! check_password "$username" "$password"; then
        log "Local auth failed for: $username"
        echo "{\"status\": \"invalid\", \"message\": \"Invalid username or password\"}"
        return 1
    fi
    
    if is_expired "$username"; then
        log "Account expired for: $username"
        echo "{\"status\": \"expired\", \"message\": \"Account has expired\"}"
        return 1
    fi
    
    if ! is_vip "$username"; then
        log "User is not VIP: $username"
        echo "{\"status\": \"not_vip\", \"message\": \"Not a VIP user\"}"
        return 1
    fi
    
    if ! check_mac "$username" "$router_mac"; then
        log "MAC check failed for: $username"
        echo "{\"status\": \"mac_mismatch\", \"message\": \"Router MAC does not match registered device\"}"
        return 1
    fi
    
    local user_type=$(get_user_type "$username")
    local expiration=$(get_expiration "$username")
    
    log "Local auth success for VIP user: $username ($user_type)"
    echo "{\"status\": \"valid\", \"message\": \"Authentication successful\", \"username\": \"$username\", \"type\": \"$user_type\", \"expiration\": \"$expiration\"}"
    return 0
}

save_auth() {
    local username="$1"
    local password="$2"
    local user_type="$3"
    local expiration="$4"
    local mac="$5"

    mkdir -p "$CONF_DIR"

    cat > "$AUTH_FILE" << EOF
username="$username"
type="$user_type"
expiration="$expiration"
mac="$mac"
auth_time="$(date '+%Y-%m-%d %H:%M:%S')"
EOF
    chmod 600 "$AUTH_FILE"

    # Save cleartext password for VPN use (openconnect needs it)
    echo -n "$password" > "$CONF_DIR/.vpn_pass"
    chmod 600 "$CONF_DIR/.vpn_pass"
}

load_auth() {
    if [ -f "$AUTH_FILE" ]; then
        cat "$AUTH_FILE"
    else
        echo ""
    fi
}

clear_auth() {
    rm -f "$CONF_DIR/auth.conf" "$CONF_DIR/.vpn_pass"
}

get_status() {
    local auth_info=$(load_auth)
    
    if [ -z "$auth_info" ]; then
        echo "{\"logged_in\": false}"
        return
    fi
    
    local username=$(echo "$auth_info" | grep "^username=" | cut -d'"' -f2)
    local user_type=$(echo "$auth_info" | grep "^type=" | cut -d'"' -f2)
    local expiration=$(echo "$auth_info" | grep "^expiration=" | cut -d'"' -f2)
    local auth_time=$(echo "$auth_info" | grep "^auth_time=" | cut -d'"' -f2)
    local mac=$(echo "$auth_info" | grep "^mac=" | cut -d'"' -f2)
    
    if [ -z "$username" ]; then
        echo "{\"logged_in\": false}"
        return
    fi

    # Check expiration from saved auth info (no DB needed)
    if [ -n "$expiration" ]; then
        local exp_ts=$(date -d "$expiration" +%s 2>/dev/null || echo "0")
        local now_ts=$(date +%s)
        if [ "$exp_ts" -gt 0 ] && [ "$exp_ts" -lt "$now_ts" ]; then
            clear_auth
            echo "{\"logged_in\": false, \"reason\": \"expired\"}"
            return
        fi
    fi

    echo "{\"logged_in\": true, \"username\": \"$username\", \"type\": \"$user_type\", \"expiration\": \"$expiration\", \"auth_time\": \"$auth_time\", \"mac\": \"$mac\"}"
}

get_renewal_url() {
    local auth_info=$(load_auth)

    if [ -z "$auth_info" ]; then
        echo "{\"success\": false, \"error\": \"not_logged_in\", \"url\": \"\"}"
        return
    fi

    local username=$(echo "$auth_info" | grep "^username=" | cut -d'"' -f2)

    if [ -z "$username" ]; then
        echo "{\"success\": false, \"error\": \"no_username\", \"url\": \"\"}"
        return
    fi

    # Request renewal URL from server (token generated server-side, no openssl needed)
    local enc_user=$(urlencode "$username")
    local mac=$(get_router_mac)
    local response=$(wget -q -O- --timeout=10 \
        "${API_BASE}/api/v1/router/renewal-url?username=${enc_user}&mac=${mac}" 2>/dev/null)

    if [ -n "$response" ]; then
        local url=$(echo "$response" | grep -o '"url":"[^"]*"' | cut -d'"' -f4)
        if [ -n "$url" ]; then
            log "Got renewal URL for user: $username"
            echo "{\"success\": true, \"username\": \"$username\", \"url\": \"$url\"}"
            return
        fi
    fi

    # Fallback: direct to renewal page with username
    local renewal_url="${RENEWAL_URL}?username=${enc_user}&source=router"
    log "Using fallback renewal URL for user: $username"
    echo "{\"success\": true, \"username\": \"$username\", \"url\": \"$renewal_url\"}"
}

case "$1" in
    login)
        if [ -z "$2" ] || [ -z "$3" ]; then
            echo "{\"status\": \"error\", \"message\": \"Usage: $0 login <username> <password> [mac]\"}"
            exit 1
        fi
        
        router_mac="$4"
        if [ -z "$router_mac" ]; then
            router_mac=$(get_router_mac)
        fi

        result=$(authenticate "$2" "$3" "$router_mac")
        
        if echo "$result" | grep -q '"status": "valid"'; then
            user_type=$(echo "$result" | grep -o '"type": *"[^"]*"' | cut -d'"' -f4)
            expiration=$(echo "$result" | grep -o '"expiration": *"[^"]*"' | cut -d'"' -f4)
            save_auth "$2" "$3" "$user_type" "$expiration" "$router_mac"
        fi
        
        echo "$result"
        ;;
    logout)
        clear_auth
        echo "{\"status\": \"success\", \"message\": \"Logged out\"}"
        ;;
    status)
        get_status
        ;;
    mac)
        echo "$(get_router_mac)"
        ;;
    refresh-key)
        fetch_encryption_key
        ;;
    check)
        auth_info=$(load_auth)
        username=$(echo "$auth_info" | grep "^username=" | cut -d'"' -f2)

        if [ -z "$username" ]; then
            echo "{\"valid\": false, \"reason\": \"not_logged_in\"}"
            exit 0
        fi

        # Use remote API to verify account validity
        enc_user=$(urlencode "$username")
        verify_resp=$(wget -q -O- --timeout=10 \
            --post-data="username=$enc_user&source=verify" \
            "${API_BASE}/api/v1/router-auth" 2>/dev/null)
        verify_status=$(echo "$verify_resp" | grep -o '"status":"[^"]*"' | cut -d'"' -f4)

        case "$verify_status" in
            valid)
                user_type=$(echo "$auth_info" | grep "^type=" | cut -d'"' -f2)
                echo "{\"valid\": true, \"username\": \"$username\", \"type\": \"$user_type\"}"
                ;;
            expired)
                clear_auth
                echo "{\"valid\": false, \"reason\": \"expired\", \"username\": \"$username\"}"
                exit 1
                ;;
            not_vip)
                clear_auth
                echo "{\"valid\": false, \"reason\": \"not_vip\", \"username\": \"$username\"}"
                exit 1
                ;;
            *)
                # API unreachable, trust local saved state
                user_type=$(echo "$auth_info" | grep "^type=" | cut -d'"' -f2)
                echo "{\"valid\": true, \"username\": \"$username\", \"type\": \"$user_type\"}"
                ;;
        esac
        ;;
    renewal-url)
        get_renewal_url
        ;;
    *)
        echo "Usage: $0 {login|logout|status|check|mac|refresh-key|renewal-url} [username] [password] [mac]"
        exit 1
        ;;
esac
