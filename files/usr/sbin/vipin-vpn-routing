#!/bin/sh
# Split tunneling: domestic IPs go direct, foreign IPs go through VPN
# Integrates with OpenWrt fw4 via nftables include to survive firewall reloads

CONF_DIR="/etc/vipin/country-ips"
NFT_RULES="/etc/nftables.d/vipin-split.nft"
TABLE_ID=100
MARK_DIRECT=0x200
LOCK_FILE="/tmp/vipin-routing.lock"

acquire_lock() {
    local wait=0
    while [ -f "$LOCK_FILE" ]; do
        # Stale lock check (>120s)
        if [ -f "$LOCK_FILE" ]; then
            local lock_age=$(( $(date +%s) - $(date -r "$LOCK_FILE" +%s 2>/dev/null || echo 0) ))
            if [ "$lock_age" -gt 120 ]; then
                logger -t vipin-routing "Removing stale lock (${lock_age}s old)"
                rm -f "$LOCK_FILE"
                break
            fi
        fi
        wait=$((wait + 1))
        if [ "$wait" -ge 60 ]; then
            logger -t vipin-routing "Timeout waiting for lock"
            return 1
        fi
        sleep 1
    done
    echo $$ > "$LOCK_FILE"
}

release_lock() {
    rm -f "$LOCK_FILE"
}

get_current_country() {
    cat "$CONF_DIR/current_country" 2>/dev/null || echo "cn"
}

get_wan_gateway() {
    ip route | grep "^default" | grep -v tun0 | head -1 | awk '{print $3}'
}

get_wan_device() {
    ip route | grep "^default" | grep -v tun0 | head -1 | awk '{print $5}'
}

get_server_country() {
    local server
    server=$(uci get vipin.vpn.server 2>/dev/null || echo "")
    if [ -n "$server" ]; then
        local country=$(echo "$server" | cut -d. -f1)
        # un.fanq.in serves Chinese IPs for overseas users, treat as cn alias
        [ "$country" = "un" ] && country="cn"
        echo "$country"
    else
        echo ""
    fi
}

# Atomically replace vipin_domestic contents with CIDRs from $1 plus
# (if present) /etc/vipin/force-cn-cidrs.txt.
# Single nft -f with leading `flush` avoids stale elements surviving a
# country switch (prior implementation assumed fw4 reload wiped the set,
# which it doesn't reliably — seen e.g. 180.160.0.0/12 lingering under ca).
# The supplementary force-cn file exists to cover overseas IP ranges that
# must still reach via tun0 (Tencent Cloud HK/SG/US edges, etc.) so the
# server at that edge sees a CN-source IP and doesn't region-block.
# Returns 0 on success, 1 if post-check shows the set is not populated.
populate_domestic_set() {
    local src_file="$1"
    local force_file="${VIPIN_CONFIG_DIR:-/etc/vipin}/force-cn-cidrs.txt"
    local merged="/tmp/vipin_nft_cidrs.txt"
    local err_log="/tmp/vipin_nft_batch.err"

    # Collect all CIDRs to load into a single dedup list first, then feed
    # nft in fixed-size chunks. On MT7628-class routers a 6k+ line single
    # `nft -f` batch silently truncates partway through (netlink buffer /
    # transaction size limits) — we were seeing 2327/6264 loaded. Splitting
    # into ~500-line transactions keeps each well under the kernel cap and
    # uses add-element semantics so no accidental flush mid-chunk.
    grep -v "^#" "$src_file" | grep -v "^$" > "$merged"

    # Append supplementary force-cn CIDRs (Tencent overseas BGP etc.)
    # — BUT only in the "overseas router + CN server" scenario. For a CN
    # router the CIDRs are irrelevant (traffic already exits from CN). For
    # an overseas router pointing at a non-CN server (e.g. jp.fanq.in),
    # forcing Tencent overseas IPs through a non-CN tunnel would worsen
    # the region check, not fix it.
    local _rc _sc _srv
    if [ "${VIPIN_VPN_MOCK:-0}" = "1" ]; then
        _rc="$VIPIN_VPN_ROUTER_COUNTRY"
        _srv="$VIPIN_VPN_UCI_SERVER"
    else
        _rc=$(/usr/sbin/vipin-country-ips get-country 2>/dev/null)
        [ -z "$_rc" ] && _rc="$(uci -q get vipin.vpn.country || echo cn)"
        _srv=$(uci -q get vipin.vpn.server 2>/dev/null)
    fi
    _sc=$(echo "$_srv" | cut -d. -f1)
    [ "$_sc" = "un" ] && _sc="cn"
    if [ "$_rc" != "cn" ] && [ "$_sc" = "cn" ] && [ -r "$force_file" ]; then
        grep -v "^#" "$force_file" | grep -v "^$" >> "$merged"
    fi

    # Flush once, then load in 500-line chunks.
    if ! nft flush set inet fw4 vipin_domestic 2>"$err_log"; then
        logger -t vipin-routing "nft flush failed: $(head -1 $err_log)"
        rm -f "$merged" "$err_log"
        return 1
    fi

    local total=$(wc -l < "$merged")
    local loaded=0
    local chunk=500
    local offset=0
    while [ "$offset" -lt "$total" ]; do
        local batch="/tmp/vipin_nft_chunk.nft"
        sed -n "$((offset + 1)),$((offset + chunk))p" "$merged" | \
            sed 's|^|add element inet fw4 vipin_domestic { |;s|$| }|' > "$batch"
        if nft -f "$batch" 2>>"$err_log"; then
            loaded=$((loaded + $(wc -l < "$batch")))
        else
            logger -t vipin-routing "nft chunk at offset $offset failed: $(tail -1 $err_log)"
        fi
        rm -f "$batch"
        offset=$((offset + chunk))
    done
    rm -f "$merged" "$err_log"

    logger -t vipin-routing "vipin_domestic loaded $loaded/$total CIDRs"

    # Post-check: first CIDR from source must hit a set element.
    # Catches silent partial-load scenarios where nft accepted some rules
    # but not the early ones.
    local first_ip
    first_ip=$(grep -v "^#" "$src_file" | grep -v "^$" | head -1 | cut -d/ -f1)
    if [ -n "$first_ip" ] && \
       ! nft get element inet fw4 vipin_domestic "{ $first_ip }" >/dev/null 2>&1; then
        logger -t vipin-routing "WARNING: post-populate check failed ($first_ip not in set)"
        return 1
    fi
    return 0
}

enable_split() {
    local country="${1:-$(get_current_country)}"
    local mode="${2:-$(uci get vipin.vpn.split_mode 2>/dev/null || echo "forward")}"

    # For reverse mode, use VPN server country if no country specified via $1
    if [ "$mode" = "reverse" ] && [ -z "$1" ]; then
        local server_country
        server_country=$(get_server_country)
        if [ -n "$server_country" ]; then
            country="$server_country"
        fi
    fi

    local domestic_file="$CONF_DIR/${country}.txt"
    local wan_gw=$(get_wan_gateway)
    local wan_dev=$(get_wan_device)

    if [ ! -f "$domestic_file" ]; then
        local attempt=1
        while [ $attempt -le 3 ]; do
            logger -t vipin-routing "No IP list for $country, downloading (attempt $attempt/3)..."
            /usr/sbin/vipin-country-ips update "$country" 2>/dev/null
            [ -f "$domestic_file" ] && break
            attempt=$((attempt + 1))
            sleep 5
        done
    fi

    if [ ! -f "$domestic_file" ]; then
        logger -t vipin-routing "Failed to get IP list for $country after 3 attempts"
        return 1
    fi

    if [ -z "$wan_gw" ] || [ -z "$wan_dev" ]; then
        logger -t vipin-routing "Cannot find WAN gateway"
        return 1
    fi

    # Skip firewall reload if same mode is already active with correct country.
    # Require BOTH sets present so a sysupgrade from v1 (which only had
    # vipin_domestic) falls through to the full rewrite path and declares
    # the new vipin_video set.
    if nft list set inet fw4 vipin_domestic >/dev/null 2>&1 && \
       nft list set inet fw4 vipin_video >/dev/null 2>&1; then
        local current_has_mark=$(nft list chain inet fw4 vipin_prerouting 2>/dev/null | grep -c "mark set")
        local current_has_return=$(nft list chain inet fw4 vipin_prerouting 2>/dev/null | grep -c "@vipin_domestic return")
        local current_has_video=$(nft list chain inet fw4 vipin_prerouting 2>/dev/null | grep -c "@vipin_video meta mark")
        local want_video=0
        [ "$(uci get vipin.vpn.video_direct 2>/dev/null || echo 1)" = "1" ] && want_video=1
        local already_correct=0
        if [ "$mode" = "reverse" ] && [ "$current_has_return" -gt 0 ] && [ "$current_has_mark" -gt 0 ]; then
            already_correct=1
        elif [ "$mode" = "forward" ] && [ "$current_has_return" -eq 0 ] && [ "$current_has_mark" -gt 0 ]; then
            already_correct=1
        fi
        # Video-rule presence must match UCI intent; otherwise force rewrite.
        if [ "$want_video" = "1" ] && [ "$current_has_video" = "0" ]; then
            already_correct=0
        elif [ "$want_video" = "0" ] && [ "$current_has_video" != "0" ]; then
            already_correct=0
        fi
        if [ "$already_correct" = "1" ]; then
            if ! populate_domestic_set "$domestic_file"; then
                logger -t vipin-routing "refresh failed, falling through to full rebuild"
            else
                ip route add default via "$wan_gw" dev "$wan_dev" table $TABLE_ID 2>/dev/null
                ip rule del fwmark $MARK_DIRECT table $TABLE_ID 2>/dev/null
                ip rule add fwmark $MARK_DIRECT table $TABLE_ID pri 100 2>/dev/null
                local ip_count=$(grep -cv "^#\|^$" "$domestic_file" 2>/dev/null || echo 0)
                logger -t vipin-routing "Split tunnel refreshed: $country, mode=$mode ($ip_count IPs, direct via $wan_dev)"
                return 0
            fi
        fi
    fi

    # Write new nftables rules then firewall reload atomically replaces them.
    # No pre-cleanup needed — fw4 reload rebuilds the entire table from
    # /etc/nftables.d/*.nft, so old chains/sets are replaced in one shot.
    mkdir -p /etc/nftables.d

    if [ "$mode" = "reverse" ]; then
        # Reverse: IPs in set → return (go through VPN), everything else → mark direct.
        # video_direct (if enabled): video CDN IPs get marked direct BEFORE the
        # domestic-return rule, so video traffic always bypasses the VPN tunnel
        # regardless of whether the CDN IP happens to fall in the VPN-country range.
        local video_rule=""
        if [ "$(uci get vipin.vpn.video_direct 2>/dev/null || echo 1)" = "1" ]; then
            video_rule="    ip daddr @vipin_video meta mark set 0x200"
        fi
        cat > "$NFT_RULES" << EOF
set vipin_domestic {
    type ipv4_addr
    flags interval
    auto-merge
}

set vipin_video {
    type ipv4_addr
    flags interval
    size 65536
}

# Router-local traffic that must ride tun0 regardless of the "always WAN"
# rule below. Exists for networks where the upstream ISP blocks outbound
# :443 (observed 2026-04-24 on a live router) — dnscrypt-proxy's DoH
# upstream IPs can't reach Cloudflare/Google via WAN on such networks,
# so we route them into the VPN tunnel where :443 gets packaged inside
# stunnel's :22. Populated with dnscrypt's configured DoH / fallback /
# netprobe targets; keep in sync with files/etc/dnscrypt-proxy/dnscrypt-proxy.toml.
set vipin_force_tun0 {
    type ipv4_addr
    flags interval
    elements = { 1.1.1.1, 1.0.0.1, 8.8.8.8, 8.8.4.4, 9.9.9.9, 149.112.112.112 }
}

chain vipin_prerouting {
    type filter hook prerouting priority mangle;
    ip daddr 10.0.0.0/8 return
    ip daddr 172.16.0.0/12 return
    ip daddr 192.168.0.0/16 return
${video_rule}
    ip daddr @vipin_domestic return
    meta mark set 0x200
}

chain vipin_output {
    type route hook output priority mangle;
    # NOTE: do NOT add 'oifname "tun0" return' here. The main routing
    # table sends every non-private destination to tun0 (via the
    # 0.0.0.0/1 + 128.0.0.0/1 pair installed by /etc/init.d/vipin-vpn
    # start_service under the stunnel+tun2socks architecture), so on the
    # first OUTPUT pass every router-originated packet has oifname=tun0
    # before we get a chance to mark it. Returning here would skip the mark
    # and blackhole all router-originated DNS/ICMP/HTTP to public IPs.
    oifname "lo" return
    ip daddr 10.0.0.0/8 return
    ip daddr 172.16.0.0/12 return
    ip daddr 192.168.0.0/16 return
    # Router-local DoH targets: override the "always WAN" rule so dnscrypt
    # can reach Cloudflare/Google on networks that block outbound :443.
    # Stays unmarked → main table → 0.0.0.0/1 dev tun0 → tunneled.
    ip daddr @vipin_force_tun0 return
    # stubby DoT must go straight out WAN, not loop back through tun0. The
    # DoT endpoint (cn.fanq.in:994) is in @vipin_domestic so would normally
    # "return" here; force-mark port 994 first.
    tcp dport 994 meta mark set 0x200
${video_rule}
    ip daddr @vipin_domestic return
    meta mark set 0x200
}

chain vipin_postrouting {
    type nat hook postrouting priority srcnat;
    oifname "tun0" masquerade
}
EOF
    else
        # Forward (default): IPs in set → mark direct, everything else → VPN
        # vipin_video set is populated by dnsmasq-full at DNS resolve time and
        # matches the same 0x200 mark → WAN direct path as vipin_domestic.
        local video_rule=""
        if [ "$(uci get vipin.vpn.video_direct 2>/dev/null || echo 1)" = "1" ]; then
            video_rule="    ip daddr @vipin_video meta mark set 0x200"
        fi
        cat > "$NFT_RULES" << EOF
set vipin_domestic {
    type ipv4_addr
    flags interval
    auto-merge
}

set vipin_video {
    type ipv4_addr
    flags interval
    size 65536
}

# See reverse-mode heredoc for rationale — keep in sync with that set.
set vipin_force_tun0 {
    type ipv4_addr
    flags interval
    elements = { 1.1.1.1, 1.0.0.1, 8.8.8.8, 8.8.4.4, 9.9.9.9, 149.112.112.112 }
}

chain vipin_prerouting {
    type filter hook prerouting priority mangle;
    ip daddr 10.0.0.0/8 return
    ip daddr 172.16.0.0/12 return
    ip daddr 192.168.0.0/16 return
    ip daddr @vipin_domestic meta mark set 0x200
${video_rule}
}

chain vipin_output {
    type route hook output priority mangle;
    # Router-originated traffic must ALWAYS take WAN, never the tunnel.
    # In forward mode, LAN clients get the "domestic direct, rest via VPN"
    # semantic through vipin_prerouting. For packets the router itself
    # emits (DNS upstream queries, NTP, update checks) we can't rely on
    # the VPN server to SNAT them back — production servers often drop
    # LAN-side source IPs sent over the tunnel. So default mark=0x200
    # here routes everything via WAN. See reverse-mode note: the original
    # 'oifname "tun0" return' preempted the mark and is removed.
    #
    # Exception: @vipin_force_tun0 IPs (dnscrypt DoH upstreams). On
    # networks that block outbound :443, WAN path is dead — force these
    # into tun0 where :443 gets packaged inside stunnel :22.
    oifname "lo" return
    ip daddr 10.0.0.0/8 return
    ip daddr 172.16.0.0/12 return
    ip daddr 192.168.0.0/16 return
    ip daddr @vipin_force_tun0 return
${video_rule}
    meta mark set 0x200
}

chain vipin_postrouting {
    type nat hook postrouting priority srcnat;
    oifname "tun0" masquerade
}
EOF
    fi

    # Create firewall include script for VPN forward rules (runs on every fw4 reload)
    mkdir -p /etc/vipin
    cat > /etc/vipin/firewall-include.sh << 'FWEOF'
#!/bin/sh
# Insert VPN forwarding and MSS clamp rules into fw4 forward chain
# This script is called by fw4 on every firewall reload
nft insert rule inet fw4 forward iifname "tun0" oifname "br-lan" ct state established,related accept 2>/dev/null
nft insert rule inet fw4 forward iifname "br-lan" oifname "tun0" accept 2>/dev/null
nft insert rule inet fw4 forward oifname "tun0" tcp flags syn tcp option maxseg size set 1260 2>/dev/null
nft insert rule inet fw4 forward iifname "tun0" tcp flags syn tcp option maxseg size set 1260 2>/dev/null
FWEOF
    chmod +x /etc/vipin/firewall-include.sh

    # Register as fw4 include (idempotent)
    if ! uci get firewall.vipin_include >/dev/null 2>&1; then
        uci set firewall.vipin_include=include
        uci set firewall.vipin_include.type='script'
        uci set firewall.vipin_include.path='/etc/vipin/firewall-include.sh'
        uci set firewall.vipin_include.fw4_compatible='1'
        uci commit firewall
    fi

    # Apply atomically via nft — nft -f runs the whole input as one kernel
    # transaction, so there is no "firewall gone" window that would drop LAN
    # traffic mid-switch. fw4 reload (which was here before) took 2-5 seconds
    # on small routers and was the cause of 断网 reports during mode toggles.
    {
        # delete-if-exists so we can reinstall cleanly
        for c in vipin_prerouting vipin_output vipin_postrouting; do
            nft list chain inet fw4 $c >/dev/null 2>&1 && \
                echo "delete chain inet fw4 $c"
        done
        for s in vipin_domestic vipin_video; do
            nft list set inet fw4 $s >/dev/null 2>&1 && \
                echo "delete set inet fw4 $s"
        done
        # re-declare into the existing fw4 table
        echo "table inet fw4 {"
        cat "$NFT_RULES"
        echo "}"
    } | nft -f - 2>/tmp/vipin-nft.err
    if ! nft list set inet fw4 vipin_domestic >/dev/null 2>&1; then
        logger -t vipin-routing "Failed to load nft rules (atomic apply): $(cat /tmp/vipin-nft.err 2>/dev/null)"
        rm -f "$NFT_RULES"
        return 1
    fi
    # Re-run forward/MSS insert rules (idempotent with ct-based nft `insert`).
    [ -x /etc/vipin/firewall-include.sh ] && /etc/vipin/firewall-include.sh 2>/dev/null

    # Populate set atomically (flush + add in single nft -f, with post-check)
    if ! populate_domestic_set "$domestic_file"; then
        logger -t vipin-routing "Failed to populate vipin_domestic for $country"
        return 1
    fi

    # Policy route: marked domestic traffic bypasses VPN via WAN
    ip route add default via "$wan_gw" dev "$wan_dev" table $TABLE_ID 2>/dev/null
    ip rule del fwmark $MARK_DIRECT table $TABLE_ID 2>/dev/null
    ip rule add fwmark $MARK_DIRECT table $TABLE_ID pri 100 2>/dev/null

    local ip_count=$(grep -cv "^#\|^$" "$domestic_file" 2>/dev/null || echo 0)
    logger -t vipin-routing "Split tunnel enabled: $country, mode=$mode ($ip_count IPs, direct via $wan_dev)"
}

disable_split() {
    # Clean up policy routing. The main-table 0.0.0.0/1 + 128.0.0.0/1 dev
    # tun0 pair stays in place — "关闭分流" semantic is full-tunnel (all
    # client traffic rides the VPN), and those routes are exactly what
    # delivers that when no fwmark rule is diverting anything back to WAN.
    ip rule del fwmark $MARK_DIRECT table $TABLE_ID 2>/dev/null
    ip route flush table $TABLE_ID 2>/dev/null

    # Atomic chain/set removal from fw4 without fw4 reload (same rationale as
    # enable_split: no LAN-drop window).
    rm -f "$NFT_RULES"
    {
        for c in vipin_prerouting vipin_output vipin_postrouting; do
            nft list chain inet fw4 $c >/dev/null 2>&1 && \
                echo "delete chain inet fw4 $c"
        done
        for s in vipin_domestic vipin_video; do
            nft list set inet fw4 $s >/dev/null 2>&1 && \
                echo "delete set inet fw4 $s"
        done
    } | nft -f - 2>/dev/null

    # Keep firewall-include.sh for VPN NAT/forward rules so VPN still works
    mkdir -p /etc/vipin
    cat > /etc/vipin/firewall-include.sh << 'FWEOF'
#!/bin/sh
# Insert VPN forwarding, NAT and MSS clamp rules into fw4 chains
nft insert rule inet fw4 forward iifname "tun0" oifname "br-lan" ct state established,related accept 2>/dev/null
nft insert rule inet fw4 forward iifname "br-lan" oifname "tun0" accept 2>/dev/null
nft insert rule inet fw4 forward oifname "tun0" tcp flags syn tcp option maxseg size set 1260 2>/dev/null
nft insert rule inet fw4 forward iifname "tun0" tcp flags syn tcp option maxseg size set 1260 2>/dev/null
nft insert rule inet fw4 srcnat oifname "tun0" masquerade 2>/dev/null
FWEOF
    chmod +x /etc/vipin/firewall-include.sh

    # Ensure fw4 include is registered (for persistence across boots/user
    # firewall edits). Only touch uci — no fw4 reload.
    uci set firewall.vipin_include=include 2>/dev/null
    uci set firewall.vipin_include.type='script' 2>/dev/null
    uci set firewall.vipin_include.path='/etc/vipin/firewall-include.sh' 2>/dev/null
    uci set firewall.vipin_include.fw4_compatible='1' 2>/dev/null
    uci commit firewall 2>/dev/null

    logger -t vipin-routing "Split tunnel disabled"
}

case "$1" in
    enable|disable|reload)
        acquire_lock || exit 1
        trap release_lock EXIT
        case "$1" in
            enable)
                enable_split "$2" "$3"
                ;;
            disable)
                disable_split
                ;;
            reload)
                split=$(uci get vipin.vpn.split_tunnel 2>/dev/null || echo "1")
                if [ "$split" = "1" ]; then
                    mode=$(uci get vipin.vpn.split_mode 2>/dev/null || echo "forward")
                    enable_split "" "$mode"
                else
                    disable_split
                fi
                ;;
        esac
        ;;
    status)
        if nft list set inet fw4 vipin_domestic >/dev/null 2>&1; then
            mode=$(uci get vipin.vpn.split_mode 2>/dev/null || echo "forward")
            if [ "$mode" = "reverse" ]; then
                country=$(get_server_country)
                [ -z "$country" ] && country=$(get_current_country)
            else
                country=$(get_current_country)
            fi
            domestic_file="$CONF_DIR/${country}.txt"
            ip_count=$(grep -cv "^#\|^$" "$domestic_file" 2>/dev/null || echo 0)
            echo "Split tunnel: enabled"
            echo "Mode: $mode"
            echo "Country: $country"
            echo "Domestic IPs: $ip_count"
        else
            echo "Split tunnel: disabled"
        fi
        ;;
    *)
        echo "Usage: $0 {enable|disable|reload|status}"
        exit 1
        ;;
esac
