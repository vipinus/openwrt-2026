#!/bin/sh
# Split tunneling: domestic IPs go direct, foreign IPs go through VPN
# Works by adding specific routes for domestic IPs via WAN gateway
# VPN's 0/1 + 128/1 routes catch everything else -> VPN

CONF_DIR="/etc/vipin/country-ips"

get_current_country() {
    cat "$CONF_DIR/current_country" 2>/dev/null || echo "cn"
}

get_wan_gateway() {
    ip route | grep "^default" | head -1 | awk '{print $3}'
}

get_wan_device() {
    ip route | grep "^default" | head -1 | awk '{print $5}'
}

enable_split() {
    local country="${1:-$(get_current_country)}"
    local domestic_file="$CONF_DIR/${country}.txt"
    local wan_gw=$(get_wan_gateway)
    local wan_dev=$(get_wan_device)

    if [ ! -f "$domestic_file" ]; then
        logger -t vipin-routing "No IP list for $country, downloading..."
        /usr/sbin/vipin-country-ips update "$country" 2>/dev/null
    fi

    if [ ! -f "$domestic_file" ]; then
        logger -t vipin-routing "Failed to get IP list for $country"
        return 1
    fi

    # Clean up old routes first
    disable_split 2>/dev/null

    # NAT masquerade for VPN traffic
    nft add table inet vipin_split 2>/dev/null
    nft add chain inet vipin_split postrouting '{ type nat hook postrouting priority srcnat; }' 2>/dev/null
    nft add rule inet vipin_split postrouting oifname "vpn_vipin" masquerade 2>/dev/null

    # Add domestic IPs as specific routes via WAN (more specific = higher priority than 0/1)
    local count=0
    grep -v "^#" "$domestic_file" | grep -v "^$" | while read -r cidr; do
        [ -z "$cidr" ] && continue
        ip route add "$cidr" via "$wan_gw" dev "$wan_dev" 2>/dev/null
        count=$((count + 1))
    done

    local ip_count=$(grep -cv "^#\|^$" "$domestic_file" 2>/dev/null || echo 0)
    logger -t vipin-routing "Split tunnel enabled: $country ($ip_count domestic routes direct via $wan_dev)"
}

disable_split() {
    local wan_gw=$(get_wan_gateway)
    local wan_dev=$(get_wan_device)

    # Remove domestic IP routes (routes added via WAN that aren't default)
    # Find routes we added: specific CIDRs via wan_gw
    if [ -n "$wan_gw" ]; then
        ip route show | grep "via $wan_gw dev $wan_dev" | grep -v "^default" | while read -r route; do
            ip route del $route 2>/dev/null
        done
    fi

    # Remove nft table
    nft delete table inet vipin_split 2>/dev/null

    logger -t vipin-routing "Split tunnel disabled"
}

case "$1" in
    enable)
        enable_split "${2:-$(get_current_country)}"
        ;;
    disable)
        disable_split
        ;;
    reload)
        split=$(uci get vipin.vpn.split_tunnel 2>/dev/null || echo "1")
        if [ "$split" = "1" ]; then
            enable_split "$(get_current_country)"
        else
            disable_split
        fi
        ;;
    status)
        if nft list tables 2>/dev/null | grep -q "vipin_split"; then
            country=$(get_current_country)
            domestic_file="$CONF_DIR/${country}.txt"
            count=$(grep -cv "^#\|^$" "$domestic_file" 2>/dev/null || echo 0)
            echo "Split tunnel: enabled"
            echo "Country: $country"
            echo "Domestic routes: $count"
        else
            echo "Split tunnel: disabled"
        fi
        ;;
    *)
        echo "Usage: $0 {enable|disable|reload|status}"
        exit 1
        ;;
esac
