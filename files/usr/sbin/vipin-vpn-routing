#!/bin/sh
VPN_RULES_FILE="/etc/firewall.vpn.rules"

add_rules() {
    local country="$1"
    local conf_dir="/etc/vipin/country-ips"
    local domestic_file="$conf_dir/${country}.txt"
    
    nft flush ruleset 2>/dev/null
    
    nft add table inet vipin_routing 2>/dev/null
    
    nft delete table inet vipin_routing 2>/dev/null
    nft add table inet vipin_routing
    
    nft add chain inet vipin_routing prerouting { type nat hook prerouting priority dstnat \; }
    nft add chain inet vipin_routing postrouting { type nat hook postrouting priority srcnat \; }
    
    nft add chain inet vipin_routing forward { type filter hook forward priority filter \; policy accept \; }
    nft add chain inet vipin_routing vpn_fwd { type filter hook forward priority filter \; policy accept \; }
    
    nft add rule inet vipin_routing postrouting oifname "vpn_vipin" masquerade
    
    nft add rule inet vipin_routing vpn_fwd iifname "vpn_vipin" counter accept
    nft add rule inet vipin_routing vpn_fwd oifname "vpn_vipin" counter accept
    
    local domestic_ips=""
    if [ -f "$domestic_file" ]; then
        domestic_ips=$(cat "$domestic_file")
    fi
    
    if [ -n "$domestic_ips" ]; then
        echo "$domestic_ips" | grep -v "^#" | grep -v "^$" | while read -r cidr; do
            [ -z "$cidr" ] && continue
            nft add rule inet vipin_routing forward ip daddr "$cidr" counter accept 2>/dev/null
        done
    fi
    
    nft add rule inet vipin_routing forward counter drop
    
    nft add chain inet vipin_routing vpn_mark { type filter hook forward priority mangle \; }
    nft add rule inet vipin_routing vpn_mark meta mark set 0x1
    
    ip route flush table 100 2>/dev/null
    ip route add default dev vpn_vipin table 100 2>/dev/null
    
    ip rule del fwmark 0x1 table 100 2>/dev/null
    ip rule add fwmark 0x1 table 100 pri 100 2>/dev/null
    
    if [ -n "$domestic_ips" ]; then
        echo "$domestic_ips" | grep -v "^#" | grep -v "^$" | while read -r cidr; do
            [ -z "$cidr" ] && continue
            ip route add "$cidr" dev "$(ip route | grep default | awk '{print $5}' | head -1)" table 100 2>/dev/null
        done
    fi
    
    cat > "$VPN_RULES_FILE" << 'EOF'
#!/bin/sh
nft flush ruleset 2>/dev/null
nft delete table inet vipin_routing 2>/dev/null
EOF
    
    chmod +x "$VPN_RULES_FILE"
    
    uci set firewall.vpn=include
    uci set firewall.vpn.path="$VPN_RULES_FILE"
    uci set firewall.vpn.reload="1"
    uci commit firewall
    /etc/init.d/firewall reload 2>/dev/null
}

remove_rules() {
    nft flush ruleset 2>/dev/null
    nft delete table inet vipin_routing 2>/dev/null
    
    ip rule del fwmark 0x1 table 100 2>/dev/null
    ip route flush table 100 2>/dev/null
    
    rm -f "$VPN_RULES_FILE"
    
    uci delete firewall.vpn 2>/dev/null
    uci commit firewall
    /etc/init.d/firewall reload 2>/dev/null
}

country_name() {
    case "$1" in
        cn) echo "China" ;;
        jp) echo "Japan" ;;
        us) echo "United States" ;;
        kr) echo "South Korea" ;;
        hk) echo "Hong Kong" ;;
        tw) echo "Taiwan" ;;
        sg) echo "Singapore" ;;
        my) echo "Malaysia" ;;
        th) echo "Thailand" ;;
        vn) echo "Vietnam" ;;
        id) echo "Indonesia" ;;
        ph) echo "Philippines" ;;
        in) echo "India" ;;
        pk) echo "Pakistan" ;;
        bd) echo "Bangladesh" ;;
        ae) echo "UAE" ;;
        sa) echo "Saudi Arabia" ;;
        tr) echo "Turkey" ;;
        ru) echo "Russia" ;;
        de) echo "Germany" ;;
        gb) echo "United Kingdom" ;;
        fr) echo "France" ;;
        nl) echo "Netherlands" ;;
        au) echo "Australia" ;;
        ca) echo "Canada" ;;
        br) echo "Brazil" ;;
        *) echo "$1" ;;
    esac
}

get_current_country() {
    cat "/etc/vipin/country-ips/current_country" 2>/dev/null || echo "cn"
}

case "$1" in
    enable)
        add_rules "${2:-$(get_current_country)}"
        ;;
    disable)
        remove_rules
        ;;
    reload)
        enabled=$(uci get vipin.vpn.enabled 2>/dev/null || echo "0")
        country=$(get_current_country)
        if [ "$enabled" = "1" ]; then
            add_rules "$country"
        else
            remove_rules
        fi
        ;;
    status)
        if nft list tables 2>/dev/null | grep -q "vipin_routing"; then
            echo "VPN routing: enabled"
        else
            echo "VPN routing: disabled"
        fi
        echo "Country: $(country_name $(get_current_country))"
        ;;
    country-name)
        country_name "$2"
        ;;
    *)
        echo "Usage: $0 {enable|disable|reload|status|country-name}"
        exit 1
        ;;
esac
