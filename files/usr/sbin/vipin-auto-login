#!/bin/sh
# Consume /etc/vipin/auto-login (baked by build.yml with caller's VPN
# creds) and hand them to vipin-auth login. Called from the WAN-ifup
# hotplug hook so DHCP + DNS are guaranteed ready before we reach out
# to the auth API.

AUTO_LOGIN=/etc/vipin/auto-login
AUTH_HOST=$(uci -q get vipin.vpn.site_url | sed 's|https\?://||;s|/.*||')
[ -z "$AUTH_HOST" ] && AUTH_HOST="www.anyfq.com"

log() { logger -t vipin-auto-login "$*"; }

[ -s "$AUTO_LOGIN" ] || exit 0

# Wait up to 60s for DNS to resolve the auth host. netifd fires ifup
# before DHCP-learned DNS is necessarily in resolv.conf.auto on every
# provider, so short-poll until nslookup succeeds.
for i in $(seq 1 20); do
    nslookup "$AUTH_HOST" >/dev/null 2>&1 && break
    sleep 3
done

if ! nslookup "$AUTH_HOST" >/dev/null 2>&1; then
    log "DNS still not ready for $AUTH_HOST after 60s — deferring (hotplug will retry next ifup)"
    exit 1
fi

USERNAME=$(sed -n '1p' "$AUTO_LOGIN")
PASSWORD=$(sed -n '2p' "$AUTO_LOGIN")

# Drop the plaintext file BEFORE contacting the API — a crash during the
# wget mustn't leave credentials readable on disk past this point.
rm -f "$AUTO_LOGIN"

if [ -z "$USERNAME" ] || [ -z "$PASSWORD" ]; then
    log "empty credentials in $AUTO_LOGIN, skipping"
    exit 0
fi

/usr/sbin/vipin-auth login "$USERNAME" "$PASSWORD" >/dev/null 2>&1
rc=$?
if [ "$rc" = "0" ]; then
    log "auto-login OK for $USERNAME"

    # Set a default VPN server if UCI has none, otherwise
    # resolve_connect_server returns empty and render_stunnel_conf
    # fails. vipin-auth status exposes "type" (jp/cn/hk/sg…) from the
    # API response — use ${type}.${base_domain} as the default. User
    # can override later via LuCI.
    if [ -z "$(uci -q get vipin.vpn.server)" ]; then
        srv_type=$(/usr/sbin/vipin-auth status 2>/dev/null | \
                   grep -o '"type": *"[^"]*"' | cut -d'"' -f4)
        base_domain=$(uci -q get vipin.vpn.base_domain || echo fanq.in)
        if [ -n "$srv_type" ]; then
            uci set vipin.vpn.server="${srv_type}.${base_domain}"
            uci commit vipin
            log "default server set to ${srv_type}.${base_domain}"
        fi
    fi

    # Kick vipin-vpn immediately. Otherwise start_service at boot
    # already check_auth-failed and exited; without this, we wait up
    # to RESTART_MIN_INTERVAL (45s) for vipin-auth-check watchdog to
    # notice the stack is down and retry. Calling start directly is
    # idempotent — if vipin-vpn is already running it's a no-op.
    /etc/init.d/vipin-vpn start >/dev/null 2>&1 &
else
    log "auto-login failed (rc=$rc); user to retry via LuCI"
fi
exit 0
