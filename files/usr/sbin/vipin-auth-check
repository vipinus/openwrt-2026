#!/bin/sh
# VIPIN Auth Monitor - background daemon (stunnel+tun2socks architecture)
# 1. Watchdog: restart VPN stack if stunnel or tun2socks died
# 2. Periodically revalidate account via remote API
# 3. Network error = no-op; explicit expired/invalid/not_vip = stop stack
# 4. Credentials are never auto-deleted (user must logout); auth_status UCI
#    drives UI + auto-recovery when the server returns ok again

LOG_FILE="/var/log/vipin-auth-check.log"
CONF_DIR="/etc/vipin"
AUTH_FILE="$CONF_DIR/auth.conf"
API_BASE=$(uci get vipin.vpn.site_url 2>/dev/null || echo "https://www.anyfq.com")
CHECK_INTERVAL=300
RECONNECT_INTERVAL=30

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
    # Keep log from growing too large
    local lines=$(wc -l < "$LOG_FILE" 2>/dev/null || echo 0)
    if [ "$lines" -gt 500 ]; then
        tail -200 "$LOG_FILE" > "$LOG_FILE.tmp"
        mv "$LOG_FILE.tmp" "$LOG_FILE"
    fi
}

has_auth_file() {
    [ -f "$AUTH_FILE" ] && [ -f "$CONF_DIR/.vpn_pass" ]
}

# MOCK mode: tests source the script and drive helpers via env.
VIPIN_AUTH_CHECK_MOCK="${VIPIN_AUTH_CHECK_MOCK:-0}"

is_stack_running() {
    if [ "$VIPIN_AUTH_CHECK_MOCK" = "1" ]; then
        [ "$VIPIN_AUTH_CHECK_STUNNEL_RUNNING" = "1" ] && \
        [ "$VIPIN_AUTH_CHECK_TUN2SOCKS_RUNNING" = "1" ]
        return
    fi
    # "Running" = processes alive + tun0 exists. That's all.
    #
    # History: earlier iterations tried to catch "zombie" states more
    # precisely. e6ff0756 added `ip -4 addr show tun0 | grep inet` —
    # FALSE POSITIVE: hev-socks5-tunnel creates tun0 as POINTOPOINT
    # with link/none by design (no router-side IP needed, it's just a
    # byte pipe to the socks5 upstream). 7dc34ec1 tried ESTAB :22 —
    # ALSO FALSE POSITIVE: stunnel's outbound connection to upstream
    # is on-demand, when idle there's no ESTAB session but the stack
    # is still functional. Both heuristics caused watchdog to thrash
    # on healthy setups.
    #
    # Functional liveness check lives in check_and_heal_dns: if
    # un.fanq.in:3333 (layer 1) or dnsmasq (layer 2) can't actually
    # resolve, that function restarts the responsible daemon. A
    # "processes alive but stack silently dead" case will still
    # manifest as DNS failure and get restarted there, just one
    # layer up.
    pgrep stunnel >/dev/null && \
        pgrep hev-socks5-tunnel >/dev/null && \
        ip link show tun0 >/dev/null 2>&1
}

get_saved_username() {
    grep "^username=" "$AUTH_FILE" 2>/dev/null | cut -d'"' -f2
}

get_saved_password() {
    cat "$CONF_DIR/.vpn_pass" 2>/dev/null
}

disable_and_stop() {
    local reason="$1"
    log "Stopping VPN: $reason"
    /etc/init.d/vipin-vpn stop 2>/dev/null
    uci set vipin.vpn.auth_status='expired'
    uci commit vipin
    log "VPN stopped; auth_status=expired. Will auto-recover when auth returns ok."
}

handle_auth_tick() {
    local username password mac api_base response status
    username=$(get_saved_username)
    password=$(get_saved_password)
    mac=$(/usr/sbin/vipin-auth mac 2>/dev/null | \
          grep -o '"mac": *"[^"]*"' | cut -d'"' -f4)

    [ -z "$username" ] && return 0

    api_base=$(uci -q get vipin.vpn.site_url || echo "https://www.anyfq.com")
    response=$(wget -q -O- --timeout=10 \
        "${api_base}/api/v1/router-auth" \
        --post-data="username=${username}&credentials=${password}&mac=${mac}&source=stunnel" \
        2>/dev/null)

    if [ -z "$response" ]; then
        log "auth API unreachable — no action"
        return 0
    fi

    status=$(echo "$response" | grep -o '"status":"[^"]*"' | cut -d'"' -f4)
    case "$status" in
        ok)
            uci set vipin.vpn.auth_status='ok'
            uci commit vipin
            if ! is_stack_running; then
                log "auth=ok and stack stopped — auto-recover"
                /etc/init.d/vipin-vpn start
            fi
            # Detect backend-pushed config drift (e.g. DNS host/port rotated
            # server-side). Only the dns.* sub-object is compared — the auth
            # envelope also includes tunnel.ca_cert and session_expires which
            # legitimately change each tick and would false-positive. If
            # changed, overwrite auth-params.json and kick vipin-dns-refresh;
            # the refresh script is idempotent (diff-based dnsmasq reload),
            # so a no-op tick costs nothing.
            new_dns=$(echo "$response" | grep -o '"dns":{[^}]*}')
            cur_dns=$(grep -o '"dns":{[^}]*}' /etc/vipin/auth-params.json 2>/dev/null)
            if [ -n "$new_dns" ] && [ "$new_dns" != "$cur_dns" ]; then
                log "backend dns config drift detected: $cur_dns → $new_dns"
                echo "$response" > /etc/vipin/auth-params.json
                /usr/sbin/vipin-dns-refresh >/dev/null 2>&1 && \
                    log "vipin-dns-refresh applied new dns config"
            fi
            ;;
        expired|invalid|not_vip)
            log "auth=$status — stopping stack, keeping credentials"
            uci set vipin.vpn.auth_status="$status"
            uci commit vipin
            /etc/init.d/vipin-vpn stop
            ;;
        *)
            log "auth returned unknown status=$status — no action"
            ;;
    esac
}

# Minimum seconds between successive vipin-vpn restarts we trigger. Prevents
# a thrash loop where the watchdog re-kicks before procd has finished the
# previous spawn, which on slow routers made the stack look permanently down.
RESTART_MIN_INTERVAL=45

# Consecutive DNS-probe failures before we restart a DNS daemon. Process-
# liveness alone misses "alive but hung" — e.g. tunnel up but the upstream
# resolver on the un side is wedged. We need a functional probe with
# per-layer recovery rather than relying on procd respawn (which only
# fires on process death).
DNS_FAIL_THRESHOLD=3
DNS_PROBE_HOST="www.anyfq.com"
UN_DNS_IP="47.242.64.28"
UN_DNS_PORT="3333"

# Probe each DNS layer independently and restart the actual faulty daemon.
# Call once per main-loop tick. Requires `now` to be set by the caller.
check_and_heal_dns() {
    # Layer 1: un.fanq.in:3333 over the hysteria2 tunnel. If this is
    # unreachable, the whole chain is dead and dnsmasq probe is
    # redundant. Recovery is to restart the tunnel (vipin-vpn), since
    # there's nothing to "restart" on the un side from here.
    if nslookup -timeout=3 -port=$UN_DNS_PORT "$DNS_PROBE_HOST" $UN_DNS_IP >/dev/null 2>&1; then
        un_dns_fails=0
    else
        un_dns_fails=$((un_dns_fails + 1))
        log "un:3333 DNS probe #$un_dns_fails/$DNS_FAIL_THRESHOLD failed"
        if [ "$un_dns_fails" -ge "$DNS_FAIL_THRESHOLD" ] && \
           [ $((now - last_un_dns_restart)) -ge "$RESTART_MIN_INTERVAL" ]; then
            log "un:3333 unresponsive — /etc/init.d/vipin-vpn restart (likely tunnel issue)"
            /etc/init.d/vipin-vpn restart 2>/dev/null
            last_un_dns_restart=$now
            un_dns_fails=0
        fi
        return
    fi

    # Layer 2: dnsmasq on 127.0.0.1:53. Only reached if upstream answered,
    # so a failure here is dnsmasq-local (hung after config reload, etc.).
    if nslookup -timeout=3 "$DNS_PROBE_HOST" 127.0.0.1 >/dev/null 2>&1; then
        dnsmasq_fails=0
    else
        dnsmasq_fails=$((dnsmasq_fails + 1))
        log "dnsmasq probe #$dnsmasq_fails/$DNS_FAIL_THRESHOLD failed (un:3333 OK)"
        if [ "$dnsmasq_fails" -ge "$DNS_FAIL_THRESHOLD" ] && \
           [ $((now - last_dnsm_restart)) -ge "$RESTART_MIN_INTERVAL" ]; then
            log "dnsmasq unresponsive — /etc/init.d/dnsmasq restart"
            /etc/init.d/dnsmasq restart 2>/dev/null
            last_dnsm_restart=$now
            dnsmasq_fails=0
        fi
    fi
}

# Path used by both the single-instance lock and the restart-serialisation
# lock. Concurrent actors (LuCI api_set_server, user-triggered restart) take
# the same file descriptor so they queue instead of racing.
WATCHDOG_LOCK=/var/lock/vipin-watchdog.lock
RESTART_LOCK=/var/lock/vipin-restart.lock

# Guard: don't run the main loop when the file is sourced for tests.
if [ "$VIPIN_AUTH_CHECK_MOCK" != "1" ]; then
    # Single-instance guard — if another vipin-auth-check is already running
    # (e.g. /etc/init.d/vipin-auth start called twice), this exec-flock exits
    # the duplicate cleanly instead of letting two watchdogs fight.
    exec 9>"$WATCHDOG_LOCK"
    if ! flock -n 9; then
        log "another vipin-auth-check is already holding the lock — exiting"
        exit 0
    fi

    log "=== VIPIN Auth Monitor Started (stunnel+tun2socks) ==="

    reconnect_fails=0
    last_verify=0
    last_restart=0
    last_un_dns_restart=0
    last_dnsm_restart=0
    un_dns_fails=0
    dnsmasq_fails=0

    while true; do
        now=$(date +%s)

        # DNS self-heal runs unconditionally — pre-login boot, post-logout,
        # post-credential-failure all depend on DNS to talk to the auth API.
        # Layered probe: restart the actual faulty daemon, not the VPN stack.
        check_and_heal_dns

        if ! has_auth_file; then
            # Fallback for pending auto-login: the WAN-ifup hotplug fires
            # vipin-auto-login exactly once. If DNS wasn't ready within
            # its 60s window (e.g. pre-my-DNS-fix firmware, or very slow
            # DHCP/ISP), the script exits without consuming creds and
            # nothing re-triggers it — auth.conf is never written and
            # the watchdog stays in this skip branch forever.
            #
            # Tick-level recovery: if baked creds are still waiting AND
            # DNS now resolves the auth host, kick vipin-auto-login. The
            # helper is idempotent (rm -f + exit-0 on missing file) so
            # concurrent invocations during a DHCP flap are safe.
            if [ -s /etc/vipin/auto-login ] && \
               nslookup -timeout=3 www.anyfq.com >/dev/null 2>&1; then
                log "auto-login still pending + DNS now ready — invoking /usr/sbin/vipin-auto-login"
                /usr/sbin/vipin-auto-login >/dev/null 2>&1 &
            fi
            sleep "$RECONNECT_INTERVAL"
            continue
        fi

        # VPN stack watchdog — only triggers on actual process death now.
        # DNS probe moved to check_and_heal_dns where it can distinguish
        # un:3333-hung vs dnsmasq-hung vs policy-route-broken (the last
        # one would still fail the check below because is_stack_running is
        # really "policy-route-complete" once tun0 comes up).
        stack_dead=0
        if ! is_stack_running; then
            stack_dead=1
        fi

        if [ "$stack_dead" = "1" ]; then
            elapsed_since_restart=$((now - last_restart))
            if [ "$elapsed_since_restart" -lt "$RESTART_MIN_INTERVAL" ]; then
                log "stack down but last restart was ${elapsed_since_restart}s ago — waiting"
            else
                log "VPN stack processes dead — calling vipin-vpn restart"
                (
                    flock 8
                    /etc/init.d/vipin-vpn restart 2>/dev/null
                ) 8>"$RESTART_LOCK"
                last_restart=$now
            fi
        elif ip link show tun0 >/dev/null 2>&1; then
            # Stack up — ensure tun0 default routes are still in place. They
            # disappear whenever hev-socks5-tunnel gets respawned (tun device
            # is recreated fresh) and start_service's one-shot poll already
            # exited. Missing routes = clients silently fall back to WAN and
            # think VPN is broken (Toronto IP on baidu, etc).
            ip route show 0.0.0.0/1 dev tun0 >/dev/null 2>&1 || \
                ip route add 0.0.0.0/1 dev tun0 2>/dev/null
            ip route show 128.0.0.0/1 dev tun0 >/dev/null 2>&1 || \
                ip route add 128.0.0.0/1 dev tun0 2>/dev/null
        fi

        # Periodic auth revalidation.
        elapsed=$((now - last_verify))
        if [ "$elapsed" -ge "$CHECK_INTERVAL" ]; then
            last_verify=$now
            handle_auth_tick
        fi

        sleep "$RECONNECT_INTERVAL"
    done
fi
