#!/bin/sh
# VIPIN Auth Monitor - background daemon
# 1. Reconnect VPN if openconnect dies
# 2. Periodically verify account is still valid via remote API
# 3. If account invalid, stop VPN and disable auto-connect

LOG_FILE="/var/log/vipin-auth-check.log"
CONF_DIR="/etc/vipin"
AUTH_FILE="$CONF_DIR/auth.conf"
API_BASE=$(uci get vipin.vpn.site_url 2>/dev/null || echo "https://www.anyfq.com")
CHECK_INTERVAL=300
RECONNECT_INTERVAL=30
MAX_RECONNECT_FAILS=5

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
    # Keep log from growing too large
    local lines=$(wc -l < "$LOG_FILE" 2>/dev/null || echo 0)
    if [ "$lines" -gt 500 ]; then
        tail -200 "$LOG_FILE" > "$LOG_FILE.tmp"
        mv "$LOG_FILE.tmp" "$LOG_FILE"
    fi
}

is_vpn_enabled() {
    local enabled=$(uci get vipin.vpn.enabled 2>/dev/null || echo "0")
    [ "$enabled" = "1" ]
}

is_vpn_running() {
    pgrep openconnect >/dev/null
}

has_auth_file() {
    [ -f "$AUTH_FILE" ] && [ -f "$CONF_DIR/.vpn_pass" ]
}

get_saved_username() {
    grep "^username=" "$AUTH_FILE" 2>/dev/null | cut -d'"' -f2
}

get_saved_password() {
    cat "$CONF_DIR/.vpn_pass" 2>/dev/null
}

# Remote check: verify account is still valid via API
remote_verify() {
    local username="$1"
    local password="$2"

    local response=$(wget -q -O- --timeout=10 \
        "${API_BASE}/api/v1/router-auth" \
        --post-data="username=$username&credentials=verify&mac=check&source=verify" \
        2>/dev/null)

    # If we can't reach the server, assume still valid (don't kill VPN on network glitch)
    if [ -z "$response" ]; then
        log "Remote verify: server unreachable, assuming valid"
        return 0
    fi

    local status=$(echo "$response" | grep -o '"status":"[^"]*"' | cut -d'"' -f4)

    case "$status" in
        expired|not_vip|invalid)
            log "Remote verify: account invalid (status=$status)"
            return 1
            ;;
        *)
            return 0
            ;;
    esac
}

disable_and_stop() {
    local reason="$1"
    log "Stopping VPN: $reason"

    # Stop VPN
    killall openconnect 2>/dev/null
    ip link delete vpn_vipin 2>/dev/null

    # Disable auto-connect
    uci set vipin.vpn.enabled=0
    uci commit vipin

    log "VPN stopped, auto-connect disabled. User needs to renew subscription."
}

reconnect_vpn() {
    log "VPN process died, reconnecting..."
    killall openconnect 2>/dev/null
    ip link delete vpn_vipin 2>/dev/null
    # Keep vipin-vpn-routing chains/sets intact during the brief reconnect
    # window. Calling `disable` here flushes @vipin_domestic and drops the
    # vipin_* chains, which opens a 10-15 s gap before `enable` rebuilds
    # them; during that gap LAN-client packets reach the now-empty chain
    # with no mark and get routed via the 0.0.0.0/1 main-table path that
    # still points to a dead vpn_vipin, so they blackhole. `vipin-vpn-
    # routing enable` is idempotent (atomic set replace + chain rewrite),
    # so the next connect refreshes everything without needing a disable.
    sleep 2
    /etc/init.d/vipin-vpn start 2>/dev/null
    sleep 10

    if is_vpn_running; then
        log "VPN reconnected successfully"
        return 0
    else
        log "VPN reconnect failed"
        return 1
    fi
}

# Main loop
log "=== VIPIN Auth Monitor Started ==="

reconnect_fails=0
last_verify=0

while true; do
    now=$(date +%s)

    if ! has_auth_file; then
        # No credentials saved, nothing to do
        sleep $CHECK_INTERVAL
        continue
    fi

    if ! is_vpn_enabled; then
        # VPN disabled, nothing to monitor
        sleep $CHECK_INTERVAL
        continue
    fi

    # Check if VPN is running, reconnect if needed
    if ! is_vpn_running; then
        reconnect_vpn
        if ! is_vpn_running; then
            reconnect_fails=$((reconnect_fails + 1))
            log "Reconnect attempt $reconnect_fails failed, will retry"
            sleep $RECONNECT_INTERVAL
            continue
        else
            reconnect_fails=0
        fi
    fi

    # Periodic remote verification
    elapsed=$((now - last_verify))
    if [ "$elapsed" -ge "$CHECK_INTERVAL" ]; then
        last_verify=$now
        username=$(get_saved_username)

        if [ -n "$username" ]; then
            if ! remote_verify "$username"; then
                disable_and_stop "Account expired or invalid for $username"
            fi
        fi
    fi

    sleep $RECONNECT_INTERVAL
done
