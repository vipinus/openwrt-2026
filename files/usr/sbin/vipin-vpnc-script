#!/bin/sh
# Custom vpnc-script for OpenWrt - configures VPN interface and routing

case "$reason" in
    pre-init)
        ;;
    connect)
        # Configure the tunnel interface
        ip link set dev "$TUNDEV" mtu 1300 up
        ip addr add "$INTERNAL_IP4_ADDRESS/32" dev "$TUNDEV"

        # Add route to VPN gateway via current default route
        DEFAULT_GW=$(ip route | grep "^default" | grep -v vpn_vipin | head -1 | awk '{print $3}')
        DEFAULT_DEV=$(ip route | grep "^default" | grep -v vpn_vipin | head -1 | awk '{print $5}')
        if [ -n "$DEFAULT_GW" ] && [ -n "$DEFAULT_DEV" ]; then
            ip route add "$VPNGATEWAY" via "$DEFAULT_GW" dev "$DEFAULT_DEV" 2>/dev/null
        fi

        # Route all traffic through VPN (0/1 + 128/1 override default route)
        # Split tunneling adds more specific domestic routes via WAN that take priority
        ip route add 0.0.0.0/1 dev "$TUNDEV" 2>/dev/null
        ip route add 128.0.0.0/1 dev "$TUNDEV" 2>/dev/null

        # DNS policy: VPN DNS is EXCLUSIVE when reachable. We don't mix it
        # with dnscrypt in parallel because dnscrypt answers from an
        # overseas resolver, which returns overseas CDN IPs for CN sites
        # (e.g. baidu → Hong Kong block) that fall outside @vipin_domestic
        # and bypass the VPN — defeating reverse-split semantics entirely.
        # Only when VPN DNS is proven dead do we fall back to dnscrypt so
        # the LAN doesn't lose DNS outright.
        uci -q delete dhcp.@dnsmasq[0].server
        # busybox ash only allows `local` inside functions; this case block
        # is plain shell, so use a regular variable.
        any_vpn_dns_live=0
        # The tunnel interface was just brought up; give it a moment before
        # firing probes, otherwise the first 1-2 packets silently drop and
        # the VPN DNS gets marked dead when it is actually fine.
        sleep 2
        if [ -n "$INTERNAL_IP4_DNS" ]; then
            for vpn_dns in $INTERNAL_IP4_DNS; do
                # Probe with a realistic query (baidu A record). Try up to
                # 3 attempts with a 4 s per-attempt timeout so a single
                # packet loss on the fresh tunnel doesn't mis-classify the
                # server as dead.
                got_answer=0
                for attempt in 1 2 3; do
                    if nslookup -timeout=4 -retry=1 www.baidu.com "$vpn_dns" 2>&1 \
                       | grep -qE "^Name:|^Address: *[0-9]+\."; then
                        got_answer=1; break
                    fi
                    sleep 1
                done
                if [ "$got_answer" = "1" ]; then
                    uci add_list dhcp.@dnsmasq[0].server="$vpn_dns"
                    any_vpn_dns_live=1
                    logger -t vpnc-script "VPN DNS $vpn_dns reachable — using (exclusive)"
                else
                    logger -t vpnc-script "VPN DNS $vpn_dns unreachable after 3 tries — skipping"
                fi
            done
        fi
        if [ "$any_vpn_dns_live" = "0" ]; then
            uci add_list dhcp.@dnsmasq[0].server='127.0.0.1#5353'
            logger -t vpnc-script "No VPN DNS reachable — falling back to dnscrypt-proxy"
        fi
        uci set dhcp.@dnsmasq[0].noresolv='1'
        uci commit dhcp
        /etc/init.d/dnsmasq restart 2>/dev/null

        # Configure IPv6 if available
        if [ -n "$INTERNAL_IP6_ADDRESS" ]; then
            ip -6 addr add "$INTERNAL_IP6_ADDRESS/$INTERNAL_IP6_NETMASK" dev "$TUNDEV" 2>/dev/null
            ip -6 route add default dev "$TUNDEV" metric 1 2>/dev/null
        fi

        # Enable split tunnel if configured (delay 3s for tunnel to stabilize)
        SPLIT=$(uci get vipin.vpn.split_tunnel 2>/dev/null || echo "1")
        if [ "$SPLIT" = "1" ]; then
            (
                sleep 3
                SPLIT_MODE=$(uci get vipin.vpn.split_mode 2>/dev/null || echo "forward")
                if [ "$SPLIT_MODE" = "reverse" ]; then
                    VPN_SERVER=$(uci get vipin.vpn.server 2>/dev/null || echo "")
                    SERVER_COUNTRY=$(echo "$VPN_SERVER" | cut -d. -f1)
                    # un.fanq.in is an overseas frontend that forwards CN
                    # traffic to cn2, so treat it as a cn alias for split.
                    [ "$SERVER_COUNTRY" = "un" ] && SERVER_COUNTRY="cn"
                    /usr/sbin/vipin-vpn-routing enable "$SERVER_COUNTRY" reverse 2>/dev/null
                else
                    /usr/sbin/vipin-vpn-routing enable "" forward 2>/dev/null
                fi
            ) &
        fi
        ;;
    disconnect)
        # Remove VPN routes
        ip route del 0.0.0.0/1 dev "$TUNDEV" 2>/dev/null
        ip route del 128.0.0.0/1 dev "$TUNDEV" 2>/dev/null
        ip route del "$VPNGATEWAY" 2>/dev/null

        # Disable split tunnel routing
        /usr/sbin/vipin-vpn-routing disable 2>/dev/null

        # DNS policy: fall back to dnscrypt-proxy, never to WAN DNS.
        uci -q delete dhcp.@dnsmasq[0].server
        uci add_list dhcp.@dnsmasq[0].server='127.0.0.1#5353'
        uci set dhcp.@dnsmasq[0].noresolv='1'
        uci commit dhcp
        /etc/init.d/dnsmasq restart 2>/dev/null
        logger -t vpnc-script "Restored dnsmasq to dnscrypt-proxy (127.0.0.1#5353)"

        # Bring down interface
        ip link set dev "$TUNDEV" down
        ;;
esac

exit 0
