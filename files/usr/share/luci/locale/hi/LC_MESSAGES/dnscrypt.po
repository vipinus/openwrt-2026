msgid "Encrypted DNS proxy supporting DNSCrypt and DNS-over-HTTPS protocols."
msgstr "DNSCrypt और DNS-over-HTTPS प्रोटोकॉल का समर्थन करने वाला एन्क्रिप्टेड DNS प्रॉक्सी।"

msgid "Enabled"
msgstr "सक्षम"

msgid "Listen Address"
msgstr "सुनने का पता"

msgid "Listen Port"
msgstr "सुनने का पोर्ट"

msgid "IPv4 Servers"
msgstr "IPv4 सर्वर"

msgid "IPv6 Servers"
msgstr "IPv6 सर्वर"

msgid "Log Level"
msgstr "लॉग स्तर"

msgid "Actions"
msgstr "कार्रवाई"

msgid "Update Now"
msgstr "अभी अपडेट करें"

msgid "Restart"
msgstr "पुनः आरंभ करें"

msgid "Debug"
msgstr "डीबग"

msgid "Info"
msgstr "जानकारी"

msgid "Warning"
msgstr "चेतावनी"

msgid "Error"
msgstr "त्रुटि"

msgid "All DNS queries are encrypted and routed through secure resolvers."
msgstr "सभी DNS क्वेरी एन्क्रिप्ट की जाती हैं और सुरक्षित रिज़ॉल्वर्स के माध्यम से रूट की जाती हैं।"

