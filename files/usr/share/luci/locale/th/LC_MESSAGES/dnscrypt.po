msgid "Actions"
msgstr "การดำเนินการ"

msgid "Update Now"
msgstr "อัปเดตเดี๋ยวนี้"

msgid "Restart"
msgstr "เริ่มต้นใหม่"

msgid "Debug"
msgstr "ดีบัก"

msgid "Info"
msgstr "ข้อมูล"

msgid "Warning"
msgstr "คำเตือน"

msgid "Error"
msgstr "ข้อผิดพลาด"

msgid "All DNS queries are encrypted and routed through secure resolvers."
