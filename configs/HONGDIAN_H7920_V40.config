CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt76x8=y
CONFIG_TARGET_ramips_mt76x8_DEVICE_hongdian_h7920-v40=y

CONFIG_LUCI_LANG_en=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_miniupnpd=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-services=y
CONFIG_PACKAGE_hev-socks5-tunnel=y
CONFIG_PACKAGE_openssl-util=y

CONFIG_PACKAGE_libxml2=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_resolveip=y
CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_libp11=y
CONFIG_PACKAGE_p11-kit=y

CONFIG_PACKAGE_lua-cjson=y

CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_odhcpd=y

CONFIG_PACKAGE_kmod-bridge=y
CONFIG_PACKAGE_kmod-nf-nat=y

# WiFi drivers: strict alignment to OpenWrt v25.12.2 Device/hongdian_h7920-v40
# DEVICE_PACKAGES. target-level defaults (wpad-basic-mbedtls, etc.) and
# mac80211/cfg80211 auto-pull via the driver dependency chain.
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_uqmi=y

CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_libopenssl-conf=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
