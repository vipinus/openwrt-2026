CONFIG_TARGET_armsr=y
CONFIG_TARGET_armsr_armv8=y
CONFIG_TARGET_armsr_armv8_DEVICE_generic=y

CONFIG_LUCI_LANG_en=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_miniupnpd=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-services=y
CONFIG_PACKAGE_hev-socks5-tunnel=y
CONFIG_PACKAGE_openssl-util=y

CONFIG_PACKAGE_libxml2=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_resolveip=y
CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_libp11=y
CONFIG_PACKAGE_p11-kit=y

CONFIG_PACKAGE_lua-cjson=y

CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_odhcpd=y

CONFIG_PACKAGE_kmod-bridge=y
CONFIG_PACKAGE_kmod-nf-nat=y

# WiFi drivers: strict alignment to OpenWrt v25.12.2 Device/generic
# DEVICE_PACKAGES. target-level defaults (wpad-basic-mbedtls, etc.) and
# mac80211/cfg80211 auto-pull via the driver dependency chain.
CONFIG_PACKAGE_kmod-amazon-ena=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-vmxnet3=y
CONFIG_PACKAGE_kmod-rtc-rx8025=y
CONFIG_PACKAGE_kmod-i2c-mux-pca954x=y
CONFIG_PACKAGE_kmod-gpio-pca953x=y
CONFIG_PACKAGE_partx-utils=y
CONFIG_PACKAGE_kmod-wdt-sp805=y
CONFIG_PACKAGE_kmod-mvneta=y
CONFIG_PACKAGE_kmod-mvpp2=y
CONFIG_PACKAGE_kmod-fsl-dpaa1-net=y
CONFIG_PACKAGE_kmod-fsl-dpaa2-net=y
CONFIG_PACKAGE_kmod-fsl-enetc-net=y
CONFIG_PACKAGE_kmod-dwmac-imx=y
CONFIG_PACKAGE_kmod-fsl-fec=y
CONFIG_PACKAGE_kmod-dwmac-rockchip=y
CONFIG_PACKAGE_kmod-dwmac-sun8i=y
CONFIG_PACKAGE_kmod-phy-aquantia=y
CONFIG_PACKAGE_kmod-phy-broadcom=y
CONFIG_PACKAGE_kmod-phy-marvell=y
CONFIG_PACKAGE_kmod-phy-marvell-10g=y
CONFIG_PACKAGE_kmod-sfp=y
CONFIG_PACKAGE_kmod-atlantic=y
CONFIG_PACKAGE_kmod-bcmgenet=y
CONFIG_PACKAGE_kmod-octeontx2-net=y
CONFIG_PACKAGE_kmod-renesas-net-avb=y
CONFIG_PACKAGE_kmod-phy-realtek=y
CONFIG_PACKAGE_kmod-phy-smsc=y
CONFIG_PACKAGE_kmod-thunderx-net=y

CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_libopenssl-conf=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
